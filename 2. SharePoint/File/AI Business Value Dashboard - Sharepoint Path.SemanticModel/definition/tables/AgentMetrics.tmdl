table AgentMetrics
	lineageTag: ff090001-0001-0001-0001-000000000001

	column AgentName
		dataType: string
		isHidden
		lineageTag: ff090001-0001-0001-0001-000000000002
		summarizeBy: none
		isNameInferred
		sourceColumn: Chat + Agent Interactions (Audit Logs)[AgentName]

		annotation SummarizationSetBy = Automatic

	column AgentLastUsedDate
		dataType: dateTime
		isHidden
		formatString: General Date
		lineageTag: ff090001-0001-0001-0001-000000000003
		summarizeBy: none
		sourceColumn: [AgentLastUsedDate]

		annotation SummarizationSetBy = Automatic

	column AgentOrgCount
		lineageTag: 5aab27d1-40aa-4e57-af9d-633b3103ccb5
		isNameInferred
		sourceColumn: [AgentOrgCount]

	partition AgentMetrics = calculated
		mode: import
		source =
				ADDCOLUMNS(
				    FILTER(
				        VALUES('Chat + Agent Interactions (Audit Logs)'[AgentName]),
				        NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentName])) && 'Chat + Agent Interactions (Audit Logs)'[AgentName] <> ""
				    ),
				    "AgentLastUsedDate", CALCULATE(
				        MAX('Chat + Agent Interactions (Audit Logs)'[InteractionDate]),
				        'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
				        NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentId]))
				    ),
				    "AgentOrgCount", CALCULATE(
				        DISTINCTCOUNT('Chat + Agent Org Data'[Organization]),
				        'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
				        NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentId]))
				    )
				)

