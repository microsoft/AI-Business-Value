table 'Unlicensed Chat User Rankings'
	lineageTag: 91eb5b41-c38a-4ff2-a8a8-c038f6858fa6

	column Audit_UserId
		lineageTag: 5e159170-d24b-4d7f-83d3-2407de3f757b
		summarizeBy: none
		isNameInferred
		sourceColumn: Chat + Agent Interactions (Audit Logs)[Audit_UserId]

		annotation SummarizationSetBy = Automatic

	column 'Usage Rank'
		lineageTag: ff84f2ba-e526-4f44-a0a8-18687663b30c
		summarizeBy: none
		isNameInferred
		sourceColumn: [Usage Rank]

		annotation SummarizationSetBy = Automatic

	column TotalPrompts
		lineageTag: f60c912d-4757-4611-aeac-68c7ac8f4846
		isNameInferred
		sourceColumn: [TotalPrompts]

	column TotalWeeks
		lineageTag: faadf1f3-6933-47d7-9dca-662415570b6b
		isNameInferred
		sourceColumn: [TotalWeeks]

	column AvgPromptsPerWeek
		lineageTag: 3308e469-6ac2-4e1a-a7e2-a775e863d99e
		isNameInferred
		sourceColumn: [AvgPromptsPerWeek]

	partition 'Unlicensed Chat User Rankings' = calculated
		mode: import
		source =
				
				VAR SummaryFull =
				    SUMMARIZE(
				        /* ignore all filters on the interactions table, including dates */
				        FILTER(
				            ALL('Chat + Agent Interactions (Audit Logs)'),
				            'Chat + Agent Interactions (Audit Logs)'[License Status] = "Unlicensed" &&
				            ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentId])
				        ),
				        'Chat + Agent Interactions (Audit Logs)'[Audit_UserId],
				        "TotalPrompts",
				            CALCULATE(
				                COUNTROWS('Chat + Agent Interactions (Audit Logs)'),
				                'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE"
				            ),
				        "TotalWeeks",
				            CALCULATE(
				                DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[WeekStart]),
				                'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE"
				            )
				    )
				
				VAR SummaryWithAvg =
				    ADDCOLUMNS(
				        SummaryFull,
				        "AvgPromptsPerWeek",
				            DIVIDE([TotalPrompts], [TotalWeeks], 0)
				    )
				
				VAR P90 = PERCENTILEX.INC(SummaryWithAvg, [AvgPromptsPerWeek], 0.90)
				VAR P75 = PERCENTILEX.INC(SummaryWithAvg, [AvgPromptsPerWeek], 0.75)
				VAR P50 = PERCENTILEX.INC(SummaryWithAvg, [AvgPromptsPerWeek], 0.50)
				VAR P25 = PERCENTILEX.INC(SummaryWithAvg, [AvgPromptsPerWeek], 0.25)
				
				RETURN
				    ADDCOLUMNS(
				        SummaryWithAvg,
				        "Usage Rank",
				            SWITCH(
				                TRUE(),
				                [AvgPromptsPerWeek] = 0 || ISBLANK([AvgPromptsPerWeek]), "0. No Usage",
				                [AvgPromptsPerWeek] >= P90, "5. Top 10% Users",
				                [AvgPromptsPerWeek] >= P75, "4. 75-90% Users",
				                [AvgPromptsPerWeek] >= P50, "3. 50-75% Users",
				                [AvgPromptsPerWeek] >= P25, "2. 25-50% Users",
				                /* else */                   "1. Bottom 25% Users"
				            )
				    )

	annotation PBI_Id = 31157c90ad204625b49b4b9e91a916e4

