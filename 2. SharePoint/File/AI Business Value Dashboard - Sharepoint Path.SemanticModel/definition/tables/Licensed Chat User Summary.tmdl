table 'Licensed Chat User Summary'
	lineageTag: e4281bb2-bb11-47a4-b1f0-b138e63eb6d9

	column Audit_UserId
		lineageTag: eb1c3eb7-28ec-4d3f-b364-f1cc5c99cfd3
		summarizeBy: none
		isNameInferred
		sourceColumn: ActiveDaysSummary[Audit_UserId]

		annotation SummarizationSetBy = Automatic

	column 'Activity Segment'
		lineageTag: 3645842d-869d-402b-a514-85994682180f
		summarizeBy: none
		isNameInferred
		sourceColumn: [Activity Segment]

		annotation SummarizationSetBy = Automatic

	column TotalActiveDays
		lineageTag: c3eba32e-894e-4d8d-b6e2-739d898a77da
		isNameInferred
		sourceColumn: [TotalActiveDays]

	column TotalMonths
		lineageTag: 3f122303-76d1-4996-823c-086d7dd46d59
		isNameInferred
		sourceColumn: [TotalMonths]

	column TotalPrompts
		lineageTag: b77a969e-8d1b-41d6-8259-d91fafa278d7
		isNameInferred
		sourceColumn: [TotalPrompts]

	column AvgActiveDaysPerMonth
		lineageTag: 13f55650-9a47-4274-a6fe-50276c6fe15e
		isNameInferred
		sourceColumn: [AvgActiveDaysPerMonth]

	partition 'Licensed Chat User Summary' = calculated
		mode: import
		source = ```
				
				ADDCOLUMNS(
				    SUMMARIZE(
				        FILTER(
				            ActiveDaysSummary,
				            ActiveDaysSummary[LicenseStatus] = "M365 Copilot Licensed"
				        ),
				        ActiveDaysSummary[Audit_UserId]
				    ),
				    "TotalActiveDays", 
				        CALCULATE(
				            SUM(ActiveDaysSummary[ChatActiveDays])
				        ),
				    "TotalMonths", 
				        CALCULATE(
				            COUNTROWS(ActiveDaysSummary),
				            ActiveDaysSummary[ChatActiveDays] > 0
				        ),
				    "TotalPrompts", 
				        CALCULATE(
				            SUM(ActiveDaysSummary[PromptCount])
				        ),
				    "AvgActiveDaysPerMonth", 
				        VAR TotalDays = CALCULATE(SUM(ActiveDaysSummary[ChatActiveDays]))
				        VAR TotalMths = CALCULATE(COUNTROWS(ActiveDaysSummary), ActiveDaysSummary[ChatActiveDays] > 0)
				        RETURN DIVIDE(TotalDays, TotalMths, 0),
				    "Activity Segment",
				        VAR TotalDays = CALCULATE(SUM(ActiveDaysSummary[ChatActiveDays]))
				        VAR TotalMths = CALCULATE(COUNTROWS(ActiveDaysSummary), ActiveDaysSummary[ChatActiveDays] > 0)
				        VAR AvgDays = DIVIDE(TotalDays, TotalMths, 0)
				        RETURN
				        SWITCH(
				            TRUE(),
				            AvgDays = 0 || ISBLANK(AvgDays), "0. No Activity",
				            AvgDays <= 5, "1. 1-5 Chat Days/Month - 'Infrequent'",
				            AvgDays <= 10, "2. 6-10 Chat Days/Month - 'Moderate'",
				            AvgDays <= 19, "3. 11-19 Chat Days/Month - 'Frequent'",
				            "4. 20+ Chat Days/Month - 'Daily'"
				        )
				)
				```

	annotation PBI_Id = cc99094e8e3f4f9799894827676a9dbe

