table ActiveDaysSummary
	lineageTag: 18741156-6935-4e73-8456-754c2b2c7b35

	column Audit_UserId
		lineageTag: 08bf4a7a-9942-4589-9143-9890b36dae42
		summarizeBy: none
		isNameInferred
		sourceColumn: Chat + Agent Interactions (Audit Logs)[Audit_UserId]

		annotation SummarizationSetBy = Automatic

	column MonthStart
		formatString: General Date
		lineageTag: ee965ec3-1e39-4cfe-a44a-4d3e2d470df4
		summarizeBy: none
		isNameInferred
		sourceColumn: Chat + Agent Interactions (Audit Logs)[MonthStart]

		annotation SummarizationSetBy = Automatic

	column ChatActiveDays
		formatString: 0
		lineageTag: d6e5a90b-ca69-473b-9f04-97e3e441b38c
		summarizeBy: sum
		isNameInferred
		sourceColumn: [ChatActiveDays]

		annotation SummarizationSetBy = Automatic

	column PromptCount
		formatString: 0
		lineageTag: a06ef304-711f-4079-9541-5c1f476ef360
		summarizeBy: sum
		isNameInferred
		sourceColumn: [PromptCount]

		annotation SummarizationSetBy = Automatic

	column LicenseStatus
		lineageTag: 07aaf7d6-7cfa-468d-a7e1-e45dc666ed7f
		summarizeBy: none
		isNameInferred
		sourceColumn: [LicenseStatus]

		annotation SummarizationSetBy = Automatic

	partition ActiveDaysSummary = calculated
		mode: import
		source = ```
				
				FILTER(
				    ADDCOLUMNS(
				        SUMMARIZE(
				            'Chat + Agent Interactions (Audit Logs)',
				            'Chat + Agent Interactions (Audit Logs)'[Audit_UserId],
				            'Chat + Agent Interactions (Audit Logs)'[MonthStart]
				        ),
				        "ChatActiveDays", 
				            CALCULATE(
				                DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[InteractionDate]),
				                'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
				                ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentId])
				            ),
				        "PromptCount",
				            CALCULATE(
				                DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Message_Id]),
				                'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
				                ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentId])
				            ),
				        "LicenseStatus",
				            CALCULATE(
				                MIN('Chat + Agent Interactions (Audit Logs)'[License Status])
				            )
				    ),
				    [ChatActiveDays] > 0
				)
				```

	annotation PBI_Id = e1a6447d60b04668be2bdfc95cd18507

