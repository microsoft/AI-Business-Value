	column 'Is Weekend'
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: fdabd548-22b4-4eea-a2bb-7bde7c8587e2
		summarizeBy: none
		isNameInferred
		sourceColumn: [Is Weekend]

		annotation SummarizationSetBy = Automatic

	partition Calendar = calculated
		mode: import
		source =
				
				VAR MinDate = MIN('Chat + Agent Interactions (Audit Logs)'[CreationDate])
				VAR MaxDate = MAX('Chat + Agent Interactions (Audit Logs)'[CreationDate])
				// Defensive fallbacks: if the source table is empty or all CreationDate values are
				// blank (e.g. JSON CreationTime parse failed), CALENDAR(BLANK, BLANK) errors with
				// "start date can not be later than end date". Anchor the range on a sensible default.
				VAR SafeMin = COALESCE(MinDate, DATE(2024, 1, 1))
				VAR SafeMax = IF(ISBLANK(MaxDate) || MaxDate < SafeMin, SafeMin, MaxDate)
				RETURN
				ADDCOLUMNS(
				    CALENDAR(SafeMin, SafeMax),
				    "Year", YEAR([Date]),
				    "Year-Month", FORMAT([Date], "YYYY-MM"),
				    "Month Name", FORMAT([Date], "MMMM"),
				    "Month Number", MONTH([Date]),
				    "Quarter", "Q" & QUARTER([Date]),
				    "Quarter Number", QUARTER([Date]),
				    "Week Number", WEEKNUM([Date], 2),
				    "Week Start", [Date] - WEEKDAY([Date], 2) + 1,
				    "Day Name", FORMAT([Date], "dddd"),
				    "Day Number", DAY([Date]),
				    "Is Weekend", WEEKDAY([Date], 1) IN {1, 7}
				)

	annotation PBI_Id = 9e947f92b0f04a85b13bffee9d5781e3

