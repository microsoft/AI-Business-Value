	partition 'Chat + Agent Org Data' = m
		mode: import
		source =
				let
				    // SharePoint URL only â€” local paths are deliberately not supported on this variant.
				    FilePath = #"Org Data File",
				    Source = Csv.Document(
				        Web.Contents(FilePath),
				        [Delimiter = ",", Encoding = 1252, QuoteStyle = QuoteStyle.None]
				    ),
				
				    PromotedHeaders = Table.PromoteHeaders(Source, [PromoteAllScalars = true]),
				    #"Trimmed Column Names" = Table.TransformColumnNames(PromotedHeaders, each Text.Trim(_)),
				
				    // Used ONLY to normalize *column names* for detection
				    Normalize = (s as text) as text =>
				        Text.Lower(Text.Remove(s, {" ", "_", "-", ".", "(", ")", "[", "]"})),
				
				    ColumnNames = Table.ColumnNames(#"Trimmed Column Names"),
				
				    // Find PersonID/UPN variant column name
				    colPersonId =
				        List.First(
				            List.Select(
				                ColumnNames,
				                (c) => List.Contains({"userprincipalname", "upn", "personid"}, Normalize(c))
				            ),
				            null
				        ),
				
				    // Rename to canonical PersonId
				    RenamedPersonId =
				        if colPersonId <> null then
				            Table.RenameColumns(
				                #"Trimmed Column Names",
				                {{colPersonId, "PersonId"}},
				                MissingField.Ignore
				            )
				        else
				            #"Trimmed Column Names",
				
				    // Find Department variant column name
				    colDepartment =
				        List.First(
				            List.Select(
				                Table.ColumnNames(RenamedPersonId),
				                (c) => Normalize(c) = "department"
				            ),
				            null
				        ),
				
				    // Rename Department to Organization (if exists)
				    RenamedColumns =
				        if colDepartment <> null then
				            Table.RenameColumns(
				                RenamedPersonId,
				                {{colDepartment, "Organization"}},
				                MissingField.Ignore
				            )
				        else
				            RenamedPersonId,
				
				    // Normalize *values* for joins (safe for UPN/email): lower + trim only
				    AddPersonIdNormalized =
				        if Table.HasColumns(RenamedColumns, "PersonId") then
				            Table.AddColumn(
				                RenamedColumns,
				                "PersonId_Normalized",
				                each try Text.Lower(Text.Trim(Text.From([PersonId]))) otherwise null,
				                type text
				            )
				        else
				            RenamedColumns,
				
				    // Ensure TotalEmployees exists
				    WithTotalEmployees =
				        if Table.HasColumns(AddPersonIdNormalized, "TotalEmployees") then
				            AddPersonIdNormalized
				        else
				            Table.AddColumn(
				                AddPersonIdNormalized,
				                "TotalEmployees",
				                each Table.RowCount(AddPersonIdNormalized)
				            ),
				
				    // Normalise JobTitle casing (Entra exports as "jobTitle", calc columns reference "JobTitle")
				    RenamedJobTitle =
				        if Table.HasColumns(WithTotalEmployees, "jobTitle") then
				            Table.RenameColumns(WithTotalEmployees, {{"jobTitle", "JobTitle"}}, MissingField.Ignore)
				        else
				            WithTotalEmployees,
				
				    // Keep ALL columns from the source CSV (Vodafone org hierarchy, management path, etc. depend on this)
				    Result = RenamedJobTitle
				in
				    Result

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

