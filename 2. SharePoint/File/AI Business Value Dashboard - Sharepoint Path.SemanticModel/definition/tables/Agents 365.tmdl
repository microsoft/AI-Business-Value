				                creatorIdCol = if List.Contains(cols, "Agent creator ID") then "Agent creator ID" else if List.Contains(cols, "Owner") then "Owner" else if List.Contains(cols, "Created by") then "Created by" else "Agent creator ID",
				                descCol = if List.Contains(cols, "Agent description") then "Agent description" else if List.Contains(cols, "Description") then "Description" else "Description",
