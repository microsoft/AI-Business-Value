	column 'Is Published' =
			-- TRUE when admin publication status is Available, OR when Status is blank
			-- (older exports don't carry Status — treat as published rather than hide everything).
			IF(
			    ISBLANK('Agents 365'[Status]) || 'Agents 365'[Status] = "",
			    TRUE(),
			    'Agents 365'[Status] = "Available"
			)
		dataType: boolean
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: cf02b2b2-2345-5ff6-a987-101122334455
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Status
		dataType: string
		lineageTag: cf7c8178-e119-4f30-9fd6-e1d7ca01fa78
		summarizeBy: none
		sourceColumn: Status

		annotation SummarizationSetBy = Automatic

	partition 'Agents 365' = m
		mode: import
		source = ```
				let
				    FilePath = #"Agent 365",
				
				    // List the column names and types as in your table output after all transforms
				    EmptyTable = #table(
				        {
				            "Agent name", "Supported in", "Date created", "Agent creator", "Agent type (A365)", 
				            "Version", "Availability", "Agent creator ID", "Agent description", "Created in", 
				            "Last updated", "Custom actions", "Title ID", "Sensitivity", 
				            "Can read OneDrive and Sharepoint items", "OneDrive and Sharepoint items", 
				            "Can read OneDrive files", "OneDrive files", "OneDrive sites",
				            "Can read Sharepoint sites and files", "Sharepoint files", "Sharepoint sites",
				            "Can extend to Graph connector", "Graph connector details", 
				            "Can generate images using user prompt", "Can use code interpreter", 
				            "Contains uploaded files", "Uploaded files"
				        },
				        {}  // No rows
				    ),
				
				    Output =
				        if FilePath <> null and Text.Trim(FilePath) <> "" then
				            let
				                // SharePoint URL only — local paths are deliberately not supported on this variant.
				                Source = Csv.Document(Web.Contents(FilePath), [Delimiter=",", Encoding=65001, QuoteStyle=QuoteStyle.None]),
				                #"Promoted Headers" = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
				
				                // Detect column name variants (old vs new format)
				                cols = Table.ColumnNames(#"Promoted Headers"),
				                nameCol = if List.Contains(cols, "Agent name") then "Agent name" else if List.Contains(cols, "Name") then "Name" else "Name",
