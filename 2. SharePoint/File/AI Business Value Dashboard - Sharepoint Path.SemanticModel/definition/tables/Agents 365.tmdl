table 'Agents 365'
	lineageTag: 42005659-2cfe-4600-a91e-6c707a2318e9

	/// Most popular shared agent creator
	/// 👤 Top agent builder
	/// 💡 Recognize and support
	measure 'Most Popular Agent Creator (Shared - Agent Builder)' = ```
			
			VAR CreatorActiveUsers = 
			    ADDCOLUMNS(
			        SUMMARIZE(
			            FILTER('Agents 365', 'Agents 365'[Agent Type Combined] = "Agent Builder"),
			            'Agents 365'[Agent creator]
			        ),
			        "@TotalUsers", 
			            CALCULATE(
			                DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			                'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
			                NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentId])),
			                'Agents 365'[Agent Type Combined] = "Agent Builder"
			            )
			    )
			VAR MaxUsers = MAXX(CreatorActiveUsers, [@TotalUsers])
			VAR MostPopularCreator = 
			    FILTER(
			        CreatorActiveUsers,
			        [@TotalUsers] = MaxUsers
			    )
			RETURN
			    CONCATENATEX(MostPopularCreator, 'Agents 365'[Agent creator], ", ")
			```
		lineageTag: 08e8a2ef-be45-41e1-931b-3d76e434147c

	/// Percentage of users who return to use this agent multiple times (2+ sessions)
	measure 'Agent Return Rate' = ```
			VAR AgentName = SELECTEDVALUE('Agents 365'[Agent name])
			
			// Get all users and their session counts for this agent
			VAR UserSessions = 
			    SUMMARIZE(
			        FILTER(
			            ALL('Chat + Agent Interactions (Audit Logs)'),
			            'Chat + Agent Interactions (Audit Logs)'[AgentName] = AgentName
			        ),
			        'Chat + Agent Interactions (Audit Logs)'[Audit_UserId],
			        "SessionCount", DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[ThreadId])
			    )
			
			// Count total unique users
			VAR TotalUsers = COUNTROWS(UserSessions)
			
			// Count users with 2+ sessions (return users)
			VAR ReturnUsers = 
			    COUNTROWS(
			        FILTER(UserSessions, [SessionCount] >= 2)
			    )
			
			RETURN
			    DIVIDE(ReturnUsers, TotalUsers, 0)
			```
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 🚀 Frontier Firm
		lineageTag: 9c1b7c1a-c6c3-4fd3-ac05-e046052851d7

	/// Return rate for the agent in current filter context. % of users with 2+ sessions.
	measure 'Agent Return Rate (Table)' =
			
			VAR UserSessions =
			    ADDCOLUMNS(
			        VALUES('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			        "@Sess", CALCULATE(
			            DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[ThreadId]),
			            'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE"
			        )
			    )
			VAR TotalUsers = COUNTROWS(UserSessions)
			VAR ReturnUsers = COUNTROWS(FILTER(UserSessions, [@Sess] >= 2)) + 0
			RETURN
			    IF(TotalUsers = 0, BLANK(), DIVIDE(ReturnUsers, TotalUsers, 0))
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 🚀 Frontier Firm
		lineageTag: feaa2630-b1d9-4ef0-91a3-e36b2ae62632

