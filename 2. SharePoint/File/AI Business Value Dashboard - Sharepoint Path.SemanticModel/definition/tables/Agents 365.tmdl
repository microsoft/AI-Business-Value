	/// Pre-calculated total users for this agent
	column 'Total Users' =
			VAR AgentName = 'Agents 365'[Agent name]
			RETURN
			    CALCULATE(
			        DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			        'Chat + Agent Interactions (Audit Logs)'[AgentName] = AgentName
			    )
		dataType: int64
		lineageTag: 576215bd-ee2b-44bd-978d-03605a14cffb
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	/// Pre-calculated organization spread
	column 'Org Count' = ```
			VAR AgentName = 'Agents 365'[Agent name]
			VAR AgentUsers = 
			    CALCULATETABLE(
			        VALUES('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			        'Chat + Agent Interactions (Audit Logs)'[AgentName] = AgentName
			    )
			RETURN
			    CALCULATE(
			        DISTINCTCOUNT('Chat + Agent Org Data'[Organization]),
			        FILTER(
			            ALL('Chat + Agent Org Data'),
			            'Chat + Agent Org Data'[PersonId] IN AgentUsers
			        )
			    )
			```
		dataType: int64
		lineageTag: e7eb4d3b-876a-4bdc-987c-9838379290d1
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	/// TRUE if this is the primary version of the agent (most users when duplicates exist)
	column 'Is Primary Agent' = ```
			VAR CurrentAgentName = 'Agents 365'[Agent name]
			VAR CurrentUsers = 'Agents 365'[Total Users]
			VAR CurrentTitleID = 'Agents 365'[Title ID]
			
			-- Find the max users for this agent name
			VAR MaxUsersForName = 
			    CALCULATE(
			        MAX('Agents 365'[Total Users]),
			        FILTER(
			            ALL('Agents 365'),
			            'Agents 365'[Agent name] = CurrentAgentName
			        )
			    )
			
			-- If there are ties, use the Title ID as tiebreaker (first alphabetically)
			VAR TitleIDWithMaxUsers = 
			    CALCULATE(
			        MIN('Agents 365'[Title ID]),
			        FILTER(
			            ALL('Agents 365'),
			            'Agents 365'[Agent name] = CurrentAgentName &&
			            'Agents 365'[Total Users] = MaxUsersForName
			        )
			    )
			
			RETURN
			    CurrentTitleID = TitleIDWithMaxUsers
			```
		dataType: boolean
		lineageTag: 9fa1db4e-af92-4f47-8944-46e07c211e73
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Sort order for Agent Review column
	column 'Agent Review Sort' = ```
			VAR InactivityStatus = 'Agents 365'[Agent Last Activity Date]
			VAR AgentType = 'Agents 365'[Agent Type Combined]
			VAR _TotalUsers = 'Agents 365'[Total Users]
			VAR _OrgCount = 'Agents 365'[Org Count]
			VAR Users = 'Agents 365'[Total Users]
			
			VAR LowUserThreshold = 
			    SWITCH(AgentType, "FirstParty", 20, "Agent Builder", 5, 10)
			VAR MinUserThreshold = 
			    SWITCH(AgentType, "FirstParty", 10, "Agent Builder", 2, 5)
			VAR HighImpactUsers = 
			    SWITCH(AgentType, "FirstParty", 100, "Agent Builder", 30, 50)
			VAR HighImpactOrgs = 
			    SWITCH(AgentType, "FirstParty", 10, "Agent Builder", 3, 5)
			
			RETURN
			    SWITCH(
			        TRUE(),
			        InactivityStatus = "6. New (Not Yet Used)", 3,
			        InactivityStatus IN {"7. Never Used (Recent)", "8. Never Used (Stale)"}, 6,
			        InactivityStatus IN {"1. Active (Last 7 days)", "2. Recent (Last 30 days)"},
			            IF(_TotalUsers >= HighImpactUsers && _OrgCount >= HighImpactOrgs, 1, 2),
			        InactivityStatus = "3. Inactive (30-60 days)" && Users < LowUserThreshold, 4,
			        InactivityStatus = "4. Dormant (60-90 days)",
			            SWITCH(TRUE(), Users < MinUserThreshold, 5, Users < LowUserThreshold, 4, 2),
			        InactivityStatus = "5. Redundant (90+ days)",
			            IF(Users < LowUserThreshold, 5, 4),
			        2
			    )
			```
		dataType: int64
		isHidden
		lineageTag: 4250a59a-df9f-4f33-90bf-350885ae9c9c
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	/// Pre-computed return rate: % of users with 2+ sessions. Calculated at refresh time for performance.
	column 'Return Rate Value' =
			
			VAR TotalUsers =
			    CALCULATE(
			        DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			        'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE"
			    )
			VAR ReturnUsers =
			    COUNTROWS(
			        FILTER(
			            ADDCOLUMNS(
			                CALCULATETABLE(
			                    VALUES('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			                    'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE"
			                ),
			                "@Sess", CALCULATE(
			                    DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[ThreadId]),
			                    'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE"
			                )
			            ),
			            [@Sess] >= 2
			        )
			    ) + 0
			RETURN
			    IF(TotalUsers = 0, BLANK(), DIVIDE(ReturnUsers, TotalUsers, 0))
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: c976c286-3469-40d2-a344-27990eb84e60
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	/// Categorized return rate: High (≥50%), Medium (20-49%), Low (<20%). Pre-computed at refresh.
	column 'Return Rate Category' =
			
			VAR Rate = 'Agents 365'[Return Rate Value]
			RETURN
			    SWITCH(
			        TRUE(),
			        ISBLANK(Rate), "No Usage",
			        Rate >= 0.50, "High",
			        Rate >= 0.20, "Medium",
			        "Low"
			    )
		lineageTag: 48a35637-aa39-474f-848e-13ae8b3fef81
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

