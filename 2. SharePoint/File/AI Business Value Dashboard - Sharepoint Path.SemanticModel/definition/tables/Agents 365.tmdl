	column 'Agent Type Combined' = ```
			
			IF(
			    'Agents 365'[Agent type (A365)] = "Shared" && 
			    'Agents 365'[Created in] = "Microsoft 365 Copilot Agent Builder",
			    "Agent Builder",
			    'Agents 365'[Agent type (A365)]
			)
			```
		lineageTag: dd221d12-3aef-458b-a221-7f6087c31d0c
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Agent Last Activity Date' = ```
			VAR LastUsedDate = 
			    CALCULATE(
			        MAX('Chat + Agent Interactions (Audit Logs)'[Agent Last Used Date])
			    )
			VAR MaxDateInData = 
			    CALCULATE(
			        MAX('Chat + Agent Interactions (Audit Logs)'[CreationDate]),
			        ALL('Chat + Agent Interactions (Audit Logs)')
			    )
			VAR AgentCreatedDate = 'Agents 365'[Date created]
			VAR DaysSinceUsed = 
			    IF(
			        NOT(ISBLANK(LastUsedDate)),
			        DATEDIFF(LastUsedDate, MaxDateInData, DAY),
			        BLANK()
			    )
			VAR DaysSinceCreated = 
			    IF(
			        NOT(ISBLANK(AgentCreatedDate)),
			        DATEDIFF(AgentCreatedDate, MaxDateInData, DAY),
			        BLANK()
			    )
			RETURN
			    SWITCH(
			        TRUE(),
			        NOT(ISBLANK(DaysSinceUsed)) && DaysSinceUsed <= 7, "1. Active (Last 7 days)",
			        NOT(ISBLANK(DaysSinceUsed)) && DaysSinceUsed <= 30, "2. Recent (Last 30 days)",
			        NOT(ISBLANK(DaysSinceUsed)) && DaysSinceUsed <= 60, "3. Inactive (30-60 days)",
			        NOT(ISBLANK(DaysSinceUsed)) && DaysSinceUsed <= 90, "4. Dormant (60-90 days)",
			        NOT(ISBLANK(DaysSinceUsed)), "5. Redundant (90+ days)",
			        ISBLANK(LastUsedDate) && DaysSinceCreated <= 14, "6. New (Not Yet Used)",
			        ISBLANK(LastUsedDate) && DaysSinceCreated <= 90, "7. Never Used (Recent)",
			        ISBLANK(LastUsedDate), "8. Never Used (Stale)",
			        "Unknown"
			    )
			```
		lineageTag: 596582bc-72c6-4755-bdad-067976ea0c39
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Agent Review' = ```
			VAR Users = 'Agents 365'[Total Users]
			VAR InactivityStatus = 'Agents 365'[Agent Last Activity Date]
			VAR AgentType = 'Agents 365'[Agent Type Combined]
			VAR _TotalUsers = 'Agents 365'[Total Users]
			VAR _OrgCount = 'Agents 365'[Org Count]
			
			// Type-specific user thresholds
			VAR LowUserThreshold = 
			    SWITCH(
			        AgentType,
			        "FirstParty", 20,
			        "Agent Builder", 5,
			        10
			    )
			
			VAR MinUserThreshold = 
			    SWITCH(
			        AgentType,
			        "FirstParty", 10,
			        "Agent Builder", 2,
			        5
			    )
			
			// High Impact thresholds (uses pre-calculated columns - fast)
			VAR HighImpactUsers = 
			    SWITCH(
			        AgentType,
			        "FirstParty", 100,
			        "Agent Builder", 30,
			        50
			    )
			VAR HighImpactOrgs = 
			    SWITCH(
			        AgentType,
			        "FirstParty", 10,
			        "Agent Builder", 3,
			        5
			    )
			
			RETURN
			    SWITCH(
			        TRUE(),
			        
			        // New agents - give them time
			        InactivityStatus = "6. New (Not Yet Used)",
			            "🆕 New",
			        
			        // Never used (not new) - created but no usage
			        InactivityStatus IN {"7. Never Used (Recent)", "8. Never Used (Stale)"},
			            "❌ Never Used",
			        
			        // Active/Recent - split into High Impact vs Keep
			        InactivityStatus IN {"1. Active (Last 7 days)", "2. Recent (Last 30 days)"}, 
			            IF(
			                _TotalUsers >= HighImpactUsers && _OrgCount >= HighImpactOrgs,
			                "🔥 High Impact",
			                "✅ Keep"
			            ),
			        
			        // 30-60 days inactive + low users = Review
			        InactivityStatus = "3. Inactive (30-60 days)" && Users < LowUserThreshold,
			            "⚠️ Review",
			        
			        // 60-90 days Dormant
			        InactivityStatus = "4. Dormant (60-90 days)",
			            SWITCH(
			                TRUE(),
			                Users < MinUserThreshold, "💤 Dormant",
			                Users < LowUserThreshold, "⚠️ Review",
			                "✅ Keep"
			            ),
			        
			        // 90+ days Redundant
			        InactivityStatus = "5. Redundant (90+ days)",
			            IF(Users < LowUserThreshold, "💤 Dormant", "⚠️ Review"),
			        
			        // Default
			        "✅ Keep"
			    )
			```
		lineageTag: 5da9ee56-b586-4e58-a717-f5d34edd6eee
		summarizeBy: none
		sortByColumn: 'Agent Review Sort'

		annotation SummarizationSetBy = Automatic

	column 'Agent Features' = ```
			
			VAR SupportedIn = 'Agents 365'[Supported in]
			
			// Platform icons + labels
			VAR HasTeams = IF(SEARCH("Teams", SupportedIn, 1, 0) > 0, "💬 in Teams ", "")
			VAR HasOutlook = IF(SEARCH("Outlook", SupportedIn, 1, 0) > 0, "📧 in Outlook ", "")
			VAR HasOffice = IF(SEARCH("Office", SupportedIn, 1, 0) > 0, "📄 in Office ", "")
			
			VAR Platforms = TRIM(HasTeams & HasOutlook & HasOffice)
			
			// Capability icons + labels (core data sources only)
			VAR SPO = IF('Agents 365'[Can read Sharepoint sites and files] = "Yes", "📁 SharePoint ", "")
			VAR OneDrive = IF('Agents 365'[Can read OneDrive files] = "Yes", "☁️ OneDrive ", "")
			VAR Graph = IF('Agents 365'[Can extend to Graph connector] = "Yes", "🔌 Graph ", "")
			VAR Files = IF('Agents 365'[Contains uploaded files] = "Yes", "📎 Files ", "")
			
			VAR Capabilities = TRIM(SPO & OneDrive & Graph & Files)
			
			// Combine with separator
			VAR Combined = 
			    IF(
			        Platforms <> "" && Capabilities <> "",
			        Platforms & " | " & Capabilities,
			        Platforms & Capabilities
			    )
			
			RETURN
			    IF(Combined = "", BLANK(), Combined)
			```
		lineageTag: 7f224cd3-5ced-48b6-9d60-9abe8fbd5da8
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

