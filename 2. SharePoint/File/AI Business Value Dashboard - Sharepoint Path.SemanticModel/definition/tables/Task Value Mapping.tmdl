	lineageTag: ff0c0001-0001-0001-0001-000000000030

	column TaskBehavior
		dataType: string
		lineageTag: ff0c0001-0001-0001-0001-000000000031
		summarizeBy: none
		sourceColumn: TaskBehavior

		annotation SummarizationSetBy = Automatic

	column WorkArchetype
