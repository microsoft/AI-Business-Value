				        {"🧠 Behaviors - Data & Analysis", "Spreadsheet Analysis", "xlsx/csv/xlsm/xlsb/xls resource + Read action. Reading or analysing spreadsheet data.", 16, 1611},
				        {"🧠 Behaviors - Knowledge & Search", "Web Searching", "WebSearchQuery resource type only (NOT plugin presence). Searching the web for information. Fix 4: BingWebSearch plugin removed as trigger to prevent false positives.", 16, 1612},
				        {"🧠 Behaviors - Knowledge & Search", "Enterprise Searching", "EnterpriseSearch plugin + aspx/ListItem resource. Searching internal org content.", 16, 1613},
