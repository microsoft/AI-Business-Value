					        {"📊 Chat (Web)  - Usage Trends", "Active Users", "Active unlicensed chat users. Breadth of organic adoption without paid licences. Target: growing MoM.", 10, 1001},
					        {"📊 Chat (Web)  - Usage Trends", "Sessions (Weekly - Per User)", "Weekly avg sessions per unlicensed user. <1/week = at-risk. >5/week = strong engagement.", 10, 1002},
					        {"📊 Chat (Web)  - Usage Trends", "MoM % Change (Sessions)", "MoM % change in unlicensed sessions. Organic growth rate. 2+ months decline = investigate.", 10, 1003},
					        {"📊 Chat (Web)  - Usage Trends", "Active Days (Weekly - Per User)", "Weekly avg active days for unlicensed chat users. Higher = building habit. Target >2 days/week.", 10, 1004},
					        {"📊 Chat (Web)  - Usage Trends", "Total Sessions", "Total chat sessions from unlicensed users. Organic demand volume. Strong growth = expand licensing.", 10, 1005},
					         {"📊 Chat (Web)  - Usage Trends", "Unlicensed Copilot - Sessions by Application", "Total chat sessions from unlicensed users split by various apps in which interactions occurred. Look for high traffic surfaces to see platforms or apps with natural gravity", 10, 1006},
				
					        {"📊 Chat (Web) - Habit Formation", "1-5 Active Days (Chat)", "Users active 1-5 days/month chatting. Target: decrease over time. Casual users — onboarding campaigns.", 11, 1101},
