					        {" 📈 M365 Copilot  - Usage Trends", "MoM % Change (Sessions)", "MoM % change in licensed sessions. Watch for 2+ months decline — may signal adoption fatigue.", 12, 1204},
					        {" 📈 M365 Copilot  - Usage Trends", "Active Days (Weekly - Per User)", "Weekly avg active days for licensed users. Higher = habitual usage. Target >3 days/week.", 12, 1205},
				
					        {" 📈 M365 Copilot - Leaderboard", "Active Users", "Total users with Copilot licence. Denominator for activation rate. Large gap vs active = onboarding issue.", 13, 1301},
					        {" 📈 M365 Copilot - Leaderboard", "MoM % Change (Sessions)", "MoM % change in licensed sessions. Momentum indicator for the licensed user base.", 13, 1302},
					        {" 📈 M365 Copilot - Leaderboard", "% Active Users", "% of licensed users actively using Copilot. Target >60%. <40% = many licences unused.", 13, 1303},
					        {" 📈 M365 Copilot - Leaderboard", "Average Copilot Active Days", "Avg active days for licensed users. Target >10. Org-wide engagement health metric.", 13, 1305},
				
					        {" 📈 M365 Copilot - Habit Formation", "M365 Copilot Actions Per User", "Avg M365 actions per licensed user. Target 50+/month. Key ROI metric combining all M365 app actions.", 14, 1401},
					        {" 📈 M365 Copilot - Habit Formation", "1-5 Active Days (Licensed)", "Licensed users active 1-5 days/month. Target: decrease. Casual users = highest risk of licence waste.", 14, 1402},
					        {" 📈 M365 Copilot - Habit Formation", "6-10 Active Days (Licensed)", "Licensed users active 6-10 days/month. Building habits. Push towards 11+ with training.", 14, 1403},
					        {" 📈 M365 Copilot - Habit Formation", "11-15 Active Days (Licensed)", "Licensed users active 11-15 days/month. Strong engagement — core licensed user base.", 14, 1404},
					        {" 📈 M365 Copilot - Habit Formation", "16+ Active Days (Licensed)", "Licensed power users (16+ days). Highest ROI users. Daily habit formed.", 14, 1405},
				
					        {"🏢 Frontier Firm Assessment", "FF Composite Score", "Weighted maturity score (0-100) combining Reach (30%), Habit (40%), and Skill (30%). Tracks overall progress towards Frontier Firm status.", 15, 1501},
					        {"🏢 Frontier Firm Assessment", "FF Pattern", "Frontier Firm pattern classification: P1 Foundation (AI assists individuals), P2 Expansion (humans orchestrate, agents execute), P3 Frontier (agents handle whole workflows).", 15, 1502},
					        {"🏢 Frontier Firm Assessment", "FF Reach Score", "Reach dimension (0-100): 60% weighted on licence activation rate + 40% on usage concentration outside top 3 orgs. Measures breadth of AI deployment.", 15, 1503},
					        {"🏢 Frontier Firm Assessment", "FF Habit Score", "Habit dimension (0-100): Licensed habitual rate (40%), agent habitual rate (30%), licensed MoM retention (30%). Measures depth of routine use.", 15, 1504},
					        {"🏢 Frontier Firm Assessment", "FF Skill Score", "Skill dimension (0-100): App surface breadth (35%), agent adoption rate (35%), deep interactions rate (30%). Measures proficiency and delegation maturity.", 15, 1505},
					        {"🏢 Frontier Firm Assessment", "App Surface Breadth", "Average number of distinct M365 app surfaces (Teams, Word, Outlook, etc.) used per active user. Target: 4+. Low = users stuck in one app.", 15, 1506},
					        {"🏢 Frontier Firm Assessment", "Agent Breadth", "Average number of distinct agents used per agent user. Higher = users exploring the agent ecosystem, not just one agent.", 15, 1507},
					        {"🏢 Frontier Firm Assessment", "Conversations with 5+ Turns %", "Percentage of conversation threads with 5+ prompts. Measures engagement depth vs. shallow single-prompt use. Target: >15%.", 15, 1508},
					        {"🏢 Frontier Firm Assessment", "Avg Prompts per Session", "Average number of prompts per conversation thread. Higher = more substantive interactions. Benchmark: 2-3 is typical.", 15, 1509},
					        {"🏢 Frontier Firm Assessment", "Usage Concentration (Outside Top 3)", "Percentage of total activity occurring outside the top 3 organisations. Higher = more even distribution. Target: >80%.", 15, 1510},
					        {"🏢 Frontier Firm Assessment", "Org Penetration (Copilot + Agents)", "Percentage of organisations where users engage with both Copilot chat AND agents. Measures cross-product adoption at org level.", 15, 1511},
					        {"🏢 Frontier Firm Assessment", "Licensed User Return Rate (MoM)", "Percentage of licensed users active in both current and previous month. Measures month-over-month user retention. Target: >90%.", 15, 1512},
					        {"🏢 Frontier Firm Assessment", "Agent Habitual Rate", "Percentage of agent users with 6+ active days in the last complete month. Measures habitual agent use. Target: >20% for P3.", 15, 1513},
					        {"🏢 Frontier Firm Assessment", "Licensed Habitual Rate", "Percentage of licensed users with 11+ active days last month. Measures habitual Copilot use. Target: >30% for P2 gate.", 15, 1514},
					        {"🏢 Frontier Firm Assessment", "Agent Sessions per User", "Average sessions per user per agent. Measures agent stickiness — higher = users returning to the same agent repeatedly.", 15, 1515},
					        {"🏢 Frontier Firm Assessment", "Meaningful Users %", "HERO REACH: Percentage of all active users with meaningful AI use (>=5 sessions in any week across M365 Copilot, Agents, or Copilot Chat). Denominator = all active users.", 15, 1516},
					        {"🏢 Frontier Firm Assessment", "Habitual Rate (12-Week)", "HERO HABIT: Percentage of users active in >=9 of the past 12 rolling weeks. A user counts as active in a week if they have >=5 sessions. Measures sustained routine use.", 15, 1517},
					        {"🏢 Frontier Firm Assessment", "Sessions with 3+ Resources %", "HERO SKILL: Percentage of sessions classified as complex. Complex = >=2 of: multi-turn (>=3 prompts), agent/tool invoked. Proxy for prompt sophistication and delegation maturity.", 15, 1518},
				
				        {"🧠 Behaviors - Communication", "Email Drafting", "Outlook/OutlookSidepane + Send/Draft actions. User actively composing or sending emails via Copilot.", 16, 1601},
				        {"🧠 Behaviors - Communication", "Email Summarising", "Outlook/OutlookSidepane + EmailMessage resource + Read action. Summarising or triaging emails.", 16, 1602},
				        {"🧠 Behaviors - Communication", "Teams Messaging", "TeamsMessage/TeamsChat/TeamsChannel resource + PostMessage/CreateChat action. Copilot assisting with Teams messages.", 16, 1603},
				        {"🧠 Behaviors - Meetings", "Meeting Prep", "Event/TeamsMeeting resource + Read action. Summarising or preparing for meetings.", 16, 1604},
				        {"🧠 Behaviors - Meetings", "Meeting Scheduling", "mcp_MeetingManagement action. Copilot managing calendar or scheduling.", 16, 1605},
				        {"🧠 Behaviors - Content Creation", "Document Drafting", "Word AppHost + Post/Write/Create actions. Creating or editing documents.", 16, 1606},
				        {"🧠 Behaviors - Content Creation", "Document Summarising", "Word AppHost + docx/doc/rtf resource + Read action. Reading or summarising Word documents.", 16, 1607},
				        {"🧠 Behaviors - Content Creation", "Presentation Creation", "PowerPoint AppHost + Post/Write/Create actions. Creating or editing presentations.", 16, 1608},
