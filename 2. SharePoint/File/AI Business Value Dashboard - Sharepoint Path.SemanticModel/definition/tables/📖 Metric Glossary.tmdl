/// Searchable metric glossary aligned to dashboard pages. Zero performance impact — pure metadata calculated table.
table '📖 Metric Glossary'
	lineageTag: 8b71f88c-7524-4ba0-a81d-f7ca7ef45b64

	measure _PageFilterActive = IF(ISFILTERED('📖 Metric Glossary'[Page]), 1, 0)
		isHidden
		lineageTag: b8d9e0f1-a2b3-4c5d-6e7f-8a9b0c1d2e3f

	column Page
		lineageTag: e5f8ce4e-0260-4641-b767-9074c969a5be
		summarizeBy: none
		isNameInferred
		sourceColumn: [Page]
		sortByColumn: PageOrder

		annotation SummarizationSetBy = Automatic

	column Metric
		lineageTag: aefccd57-48ba-41be-8726-4e7171c5fae7
		summarizeBy: none
		isNameInferred
		sourceColumn: [Metric]
		sortByColumn: MetricOrder

		annotation SummarizationSetBy = Automatic

	column Description
		lineageTag: c360df21-ff12-4418-a672-1f2b7becde62
		summarizeBy: none
		isNameInferred
		sourceColumn: [Description]

		annotation SummarizationSetBy = Automatic

	column PageOrder
		isHidden
		formatString: 0
		lineageTag: a7c1d2e3-f4b5-4c6d-8e9f-0a1b2c3d4e5f
		summarizeBy: sum
		isNameInferred
		sourceColumn: [PageOrder]

		annotation SummarizationSetBy = Automatic

	column MetricOrder
		isHidden
		formatString: 0
		lineageTag: e643cc8e-fde1-4c40-83bd-5bfad861217c
		summarizeBy: sum
		isNameInferred
		sourceColumn: [MetricOrder]

		annotation SummarizationSetBy = Automatic

	partition '📖 Metric Glossary' = calculated
		mode: import
		source =
					DATATABLE(
					    "Page", STRING,
					    "Metric", STRING,
					    "Description", STRING,
					    "PageOrder", INTEGER,
					    "MetricOrder", INTEGER,
					    {
					        {"🔍Copilot Overall - Combined Trends", "Agent Active Users", "Count of users who have used any agent. Target >20% of total users. Low = improve agent promotion strategy.", 1, 101},
					        {"🔍Copilot Overall - Combined Trends", "Unlicensed Chat Active Users", "Unlicensed users with chat activity. Shows organic demand beyond licensed seats — strong pipeline for licence allocation.", 1, 102},
					        {"🔍Copilot Overall - Combined Trends", "M365 Copilot Active Users", "Licensed users with chat activity. Target: Growing MoM. Sustained growth = healthy rollout; flat = engagement gap.", 1, 103},
					        {"🔍Copilot Overall - Combined Trends", "Weekly Agent Sessions Per User", "Avg agent sessions per user across both M365 Copilot and Unlicensed Chat. Trend is more important than absolute value.", 1, 104},
					        {"🔍Copilot Overall - Combined Trends", "Weekly Unlicensed Chat Sessions Per User", "Avg sessions for unlicensed active users. If close to licensed, these users are strong licence candidates.", 1, 105},
					        {"🔍Copilot Overall - Combined Trends", "Weekly M365 Copilot Sessions Per User", "Avg sessions for licensed active users. Target >20/month. Low = poor value realisation from paid licences.", 1, 106},
					        {"🔍Copilot Overall - Combined Trends", "Agent Active Days Per User", "Avg days/month a user interacts with agents. Target >8. Compare to chat days — large gap = agent awareness opportunity.", 1, 107},
					        {"🔍Copilot Overall - Combined Trends", "Chat Active Days Per User", "Avg days/month a user chats with Copilot. <5=casual, 5-10=regular, 10-15=engaged, 16+=power user. Target >10.", 1, 108},
					        {"🔍Copilot Overall - Combined Trends", "M365 Copilot Active Days Per User", "Avg days/month a user interacts with M365 Copilot. <5=casual, 5-10=regular, 10-15=engaged, 16+=power user. Target >10.", 1, 109},
					        {"🔍Copilot Overall - Combined Leaderboard", "Agent Users", "Count of users who have used any agent. Target >20% of total users. Low = improve agent promotion strategy.", 2, 201},
					        {"🔍Copilot Overall - Combined Leaderboard", "Weekly Agent Sessions Per User", "Average number of sessions an active user of agents engaged in a week", 2, 202},
					        {"🔍Copilot Overall - Combined Leaderboard", "Unlicensed Chat Users", "Unlicensed users actively using Copilot Chat. Target: Growing MoM. Shows organic demand beyond paid seats — strong pipeline for licence allocation.", 2, 203},
					        {"🔍Copilot Overall - Combined Leaderboard", "Weekly Unlicensed Chat User Sessions", "Average weekly chat sessions per unlicensed active user. If approaching licensed user levels, these are strong licence upgrade candidates.", 2, 204},
					        {"🔍Copilot Overall - Combined Leaderboard", "M365 Copilot Users", "Total users with Copilot licence enabled. Compare to active count — large gap = activation problem.", 2, 205},
					        {"🔍Copilot Overall - Combined Leaderboard", "Weekly Copilot Sessions Per User", "Average weekly sessions per licensed M365 Copilot user. Target >5/week. Low = underutilised licences — investigate adoption blockers.", 2, 206},
					        {"🔍Copilot Overall - Combined Leaderboard", "% Copilot Users Using Agents (Licensed)", "% of licensed users also using agents. Target >30%. <15% = improve agent discoverability.", 2, 207},
					        {"🔍Copilot Overall - Combined Leaderboard", "% Chat Users Using Agents (Unlicensed)", "% of unlicensed users also using agents. Target >20%. High = agents solving real problems.", 2, 208},
					        {"🔍Copilot Overall - Combined Leaderboard", "% Active Users", "% of enabled users actively using Copilot. Target >60%. <40% = many licences unused.", 2, 209},
					        {"🔍Copilot Overall - Combined Leaderboard", "% Users with 5+ Behaviors & Agents", "% in highest engagement tier. Target: growing over time, aim for 15-25%.", 2, 210},
					        {"🔍Copilot Overall - Combined Leaderboard", "% Non Users", "% of enabled users with no activity. Target: decreasing. High % = wasted licences.", 2, 211},
					        {"🔍Copilot Overall - Combined Leaderboard", "Average Copilot Active Days", "Avg active days across all Copilot users. Target >10. Compare across departments.", 2, 212},
					        {"🤖 Agents  - Usage Trends", "Most Popular Agent", "Agent with highest session count. Study its design and use case for replication patterns.", 3, 301},
					        {"🤖 Agents  - Usage Trends", "Most Versatile Agent", "Agent used by most number of unique users. Reflects broad applicability", 3, 302},
					        {"🤖 Agents  - Usage Trends", "Users", "Count of users who have used any agent. Target >20% of active users. Track growth MoM.", 3, 303},
					        {"🤖 Agents  - Usage Trends", "Users Adopt Agents", "% of all active users also using agents. <15% = awareness problem. >40% = excellent adoption.", 3, 304},
					        {"🤖 Agents  - Usage Trends", "Agent Sessions MoM %", "Month-over-month % change in agent sessions. Should outpace chat growth. 2+ months decline = investigate.", 3, 305},
					        {"🤖 Agents  - Usage Trends", "Agent Return Rate", "% of users who return to an agent 2+ times. Target >50%. Low = agents not solving real problems.", 3, 306},
					        {"🤖 Agents  - Usage Trends", "Total Agent Sessions", "Total sessions involving agent interactions. Target: growing share of total sessions over time.", 3, 307},
					        {"🤖 Agents  - Usage Trends", "Agent Active Users", "Weekly count of users who interacted with any agent. Target: growing MoM. Flat or declining = revisit agent discoverability and promotion.", 3, 308},
					        {"🤖 Agents  - Usage Trends", "Sessions", "Weekly total agent sessions. Tracks overall engagement volume. Rising sessions with stable users = deeper habit formation.", 3, 309},
					        {"🤖 Agents  - Usage Trends", "Number of Sessions by Agent", "Total sessions per agent for the selected time period. Only agents with 3 or more users are included to ensure statistical reliability and protect user privacy.", 3, 310},
					        {"🤖 Agents  - Habit Formation", "1-5 Active Days (Agent)", "Users active 1-5 days/month with agents. Target: decrease over time. Casual users — target with agent training.", 4, 401},
					        {"🤖 Agents  - Habit Formation", "6-10 Active Days (Agent)", "Users active 6-10 days/month with agents. Target: growing. Push towards 11+ with advanced use cases.", 4, 402},
					        {"🤖 Agents  - Habit Formation", "11-15 Active Days (Agent)", "Users active 11-15 days/month with agents. Strong engagement. Study their workflows for best practices.", 4, 403},
					        {"🤖 Agents  - Habit Formation", "16+ Active Days (Agent)", "Power agent users with daily habit (16+ days). Champions. Leverage as mentors and advocates.", 4, 404},
					        {"🤖 Agents  - Habit Formation", "Total Agent Sessions", "Total sessions involving agents. Target: growing MoM. Combine with active days for full picture.", 4, 405},
					        {"🤖 Agents - Leaderboard", "Top Builder", "Creator with the highest unique user count. Identify top builders who have the widest user reach.", 5, 501},
					        {"🤖 Agents - Leaderboard", "High Impact Agents", "An agent that is active and widely adopted (many users, many orgs). Key thresholds: for 1P agents, 100 users or 10 orgs, Agent Builder, 30 users or 3 orgs, others 50 users or 5 orgs ", 5, 502},
					        {"🤖 Agents - Leaderboard", "Dormant Agents", "Agents with minimal usage after 90+ days. Minimise count. Archive candidates — consult creator before removing. For 1P agent the thresholds would be inactive for 2–3 months and has fewer than 10 users", 5, 503},
					        {"🤖 Agents - Leaderboard", "Agent Return Rate", "% of users who return to an agent 2+ times. Target >50%. Quality signal for agent portfolio.", 5, 504},
				
					        {"🤖 Agents - Health Check", "Most Popular Agent", "Agent with highest session count. Study its design, prompts, and use case for replication.", 6, 601},
					        {"🤖 Agents - Health Check", "Most Versatile Agent", "Agent used by most number of unique users. Reflects broad applicability.", 6, 602},
					        {"🤖 Agents - Health Check", "High Impact Agents", "An agent that is active and widely adopted (many users, many orgs). Key thresholds: for 1P agents, 100 users or 10 orgs, Agent Builder, 30 users or 3 orgs, others 50 users or 5 orgs", 6, 603},
					        {"🤖 Agents - Health Check", "Dormant Agents", "Agents with minimal usage after 90+ days. Minimise count. Archive candidates — consult creator before removing. For 1P agent the thresholds would be inactive for 2–3 months and has fewer than 10 users", 6, 604},
					        {"🤖 Agents - Health Check", "Agent Return Rate", "% of users returning to agents 2+ times. Overall portfolio quality signal. Target >50%.", 6, 605},
					        {"🤖 Agents - Use Cases", "Total Agent Sessions", "Total sessions involving agents across all use cases. Target: growing MoM.", 7, 701},
					        {"🤖 Agents - Use Cases", "Users", "Users who have used any agent. Breadth of agent adoption across the organisation.", 7, 702},
				
					        {"📊 License Prioritisation", "Unlicensed Active Users", "Unlicensed active user count. Total addressable market for new licence allocation.", 8, 801},
					        {"📊 License Prioritisation", "Licensed Active Users", "Licensed active user count. Context for licence allocation — how many current licences are active.", 8, 802},
					        {"📊 License Prioritisation", "License Priority Rank", "Dynamic ranking of unlicensed users for licence candidacy. Based on usage volume + consistency. Filter by dept for best candidates.", 8, 803},
					        {"📊 License Prioritisation", "Median Sessions Per User (Weekly)", "Median weekly sessions for unlicensed users.", 8, 804},
