				        {"📈 Value Metrics", "Technical Capability", "AI enabling technical work users couldn't do before. Fed by: Code Writing, Code Analysis, Code Analysis (URL). Proxy: code files modified, non-tech users writing code.", 18, 1807},
				        {"📈 Value Metrics", "Workflow Automation", "AI triggering automated processes. Fed by: Workflow Execution, Autonomous Agents. Proxy: flows invoked, manual steps eliminated.", 18, 1808},
				        {"📈 Value Metrics", "Task & Project Management", "AI managing tasks and projects. Fed by: Task Management (Planner). Proxy: tasks created/managed via AI.", 18, 1809},
				        {"📈 Value Metrics", "HR Operations", "AI performing HR specialist work. Fed by: Agent: HR & People. Proxy: JDs created, screening sessions, onboarding completions.", 18, 1810},
				        {"📈 Value Metrics", "Domain Expertise", "AI providing specialist domain knowledge. Fed by: Domain-Specific Agent, Cross-Org Agent. Proxy: agent sessions per function.", 18, 1811},
				        {"📈 Value Metrics", "Collaboration & Knowledge", "AI supporting teamwork and knowledge capture. Fed by: Real-time Collaboration, Note Taking, Form/Survey Work. Proxy: shared sessions, notes created.", 18, 1812},
				        {"📈 Value Metrics", "Autonomous Value", "Value from autonomous agents. Any behavior where Environment = Autonomous Agent. Proxy: actions completed with 0 human prompts.", 18, 1810},
				        {"📈 Value Metrics", "Security & Compliance", "Governance and compliance awareness. Fed by: sensitive data interactions + security flag detections. Proxy: % sensitive + jailbreak rate.", 18, 1811},
				
				        {"🎯 User Maturity Stages", "Beginner Users", "Users with fewer than 3 behavior categories OR fewer than 3 active days. Light touch — mostly general chat and simple Q&A.", 19, 1901},
				        {"🎯 User Maturity Stages", "Developing Users", "Users with 3+ behavior categories AND 3+ active days (but below Proficient). Consistent, multi-workflow use.", 19, 1902},
				        {"🎯 User Maturity Stages", "Proficient Users", "Users with 5+ behavior categories AND 8+ active days. AI is habitual across many workflows — a genuinely engaged user.", 19, 1903},
				        {"🎯 User Maturity Stages", "Proficient Users %", "Percentage of active users at Proficient stage. Single best indicator of real AI maturity. Target: growing MoM.", 19, 1905},
				        {"🎯 User Maturity Stages", "User_Stage_Maturity", "Per-row user stage via lookup to UserMonthMetrics[UserStage]. Use this column on maturity page visuals.", 19, 1907},
				        {"🎯 User Maturity Stages", "4W Rolling Stage Measures", "4W Beginner/Developing/Proficient Users. For each week, looks back 4 weeks and counts users per stage. Use on weekly trend charts.", 19, 1908},
				
				        {"🔬 Stage Profiles", "Stage Users", "Distinct user count within the filtered maturity stage. Responds to visual-level filter on User_Stage_Maturity.", 20, 2001},
				        {"🔬 Stage Profiles", "Stage Top Org", "Organisation with the most users in the currently filtered maturity stage.", 20, 2002},
				        {"🔬 Stage Profiles", "Stage Avg Behaviors", "Average distinct enriched behaviors per user within the filtered stage. Higher = broader AI usage.", 20, 2003},
				        {"🔬 Stage Profiles", "Stage Avg Active Days", "Average active days per user within the filtered stage.", 20, 2004},
				        {"🔬 Stage Profiles", "Distinct Behaviors", "Count of distinct Behavior_Enriched_Full values. Use on Value Outcome rows to show behavior variety per value.", 20, 2005},
				        {"🔬 Stage Profiles", "Value Usage %", "% of users in the current stage accessing each value outcome. Normalised for stage size.", 20, 2006},
				        {"🔬 Stage Profiles", "Behavior Penetration %", "% of users in the current filter context doing each behavior. Normalises across stages for fair comparison.", 20, 2007},
				
				        {"📊 Story Insights", "Top Value Outcome", "The value outcome with the most users (excluding General AI Assistance). Uses Behavior_Enriched_Full for richer classification.", 21, 2101},
				        {"📊 Story Insights", "Top Behavior", "The most common enriched behavior (excluding General Chat). Uses Behavior_Enriched_Full.", 21, 2102},
				        {"📊 Story Insights", "Rarest Behavior", "The least common enriched behavior (excluding General Chat and Agent: General Purpose). Biggest growth opportunity.", 21, 2103},
				        {"📊 Story Insights", "Top Unrealised Value", "Value outcome from the Behavior Value Map with the LOWEST user adoption. Biggest opportunity gap.", 21, 2104},
				        {"📊 Story Insights", "Top Unrealised Value %", "How low the adoption is for the least-adopted value outcome.", 21, 2105},
				        {"📊 Story Insights", "Top Unrealised Behavior", "The specific behavior with the lowest adoption rate. Direct 'enable this next' recommendation.", 21, 2106},
				
				        {"🌐 Environment", "Agents", "All agent interactions (custom agents built in Copilot Studio or other platforms).", 22, 2201},
				        {"🌐 Environment", "Autonomous Agent", "System-initiated agent actions with no human prompt (AppHost = autonomous).", 22, 2202},
				        {"🌐 Environment", "Licensed M365 Copilot", "Licensed users interacting via Copilot Chat (non-agent). Has license = TRUE/YES.", 22, 2203},
				        {"🌐 Environment", "Unlicensed Chat", "Unlicensed users interacting via Copilot Chat (non-agent). Organic demand beyond paid seats.", 22, 2204},
				
				        {"🚀 AI Usage Modes", "1 - Asking", "Bloom''s: Remember. Using AI as a search engine. General chat, Q&A with no document grounding. The user asks a question, gets a text response. The entry point for all users.", 23, 2301},
				        {"🚀 AI Usage Modes", "2 - Consuming", "Bloom''s: Understand. Using AI to process and digest existing content. Doc/email/presentation summarising, video recaps, meeting prep, note taking, AI-assisted Teams messaging and meeting scheduling. AI handles information the user already has access to.", 23, 2302},
				        {"🚀 AI Usage Modes", "3 - Finding", "Bloom''s: Apply. Using AI to locate and retrieve information from systems. Web search, enterprise search, PDF analysis, SharePoint browsing, people lookup, spreadsheet review, knowledge base agents. Unlike Consuming (digests what you have), Finding goes out and retrieves what you don''t have.", 23, 2303},
				        {"🚀 AI Usage Modes", "4 - Producing", "Bloom''s: Create + Expert Create. AI produces new output or performs specialist work. Covers document/email/presentation drafting, code writing, image generation, data analysis, workflow automation, specialist agents (Sales, HR, IT, Compliance, Coaching). The highest maturity tier — AI is creating deliverables or acting as a specialist colleague.", 23, 2304},
				        {"🚀 AI Usage Modes", "Productive AI Rate", "% of interactions that are Producing. Measures how much AI usage produces tangible output or specialist work vs just consuming information.", 23, 2307},
				        {"🚀 AI Usage Modes", "% of Users in Stage", "% of users in the current maturity stage who are leveraging this Usage Mode or Behavior. Works at both the mode level and the drill-down behavior level. Denominator = all users in the stage.", 23, 2308},
				        {"🚀 AI Usage Modes", "Workflow App Rate", "% of sessions in workflow apps (Outlook, Word, Excel, PPT, SharePoint) vs exploration apps (Edge, Teams chat). Higher = AI embedded in daily work tools, not just used for browsing.", 23, 2309},
				
				        {"🚀 AI Usage Modes", "Why Asking?", "Behaviors here have no document grounding, no resource context, no output artefact. The user asks, AI answers, done. It is the entry point for all users.", 23, 2310},
				        {"🚀 AI Usage Modes", "Why Consuming?", "Behaviors here process EXISTING content (documents, emails, videos). AI reads for you. The input already exists — AI just distils it. Value = reading time saved.", 23, 2311},
				        {"🚀 AI Usage Modes", "Why Finding?", "Behaviors here navigate information SYSTEMS (web, SharePoint, enterprise search). Unlike Consuming (digests what you have), Finding retrieves what you don't have yet. Value = search time saved.", 23, 2312},
				        {"🚀 AI Usage Modes", "Why Producing?", "Behaviors here either CREATE new artefacts (emails, docs, decks, images, code) or ORCHESTRATE specialist work (data analysis, compliance checking, workflow automation, agent delegation). AI produces deliverables or acts as an expert colleague. The highest maturity tier.", 23, 2313},
				
				        {"👤 User Stages", "1 - Beginner", "Tries AI occasionally for simple tasks. Fewer than 3 task types, no agents, fewer than 6 active days. Mostly Q&A and basic lookups.", 24, 2401},
				        {"👤 User Stages", "2 - Developing", "Uses AI regularly across multiple workflows. 3+ task types, OR agent use, OR 6+ active days. Email, documents, meetings, search.", 24, 2402},
				        {"👤 User Stages", "3 - Proficient", "AI is embedded in how they work every day. 5+ task types AND (agents or 8+ active days). Produces work, accesses specialist expertise.", 24, 2403},
				
				        {"🔍 Conversation Depth", "Avg Turns Per Session", "Average prompts per thread. Typically 1.3-1.5 across all stages. Depth is driven by activity type (Outlook=3.8, Word=1.2), not maturity.", 25, 2501},
				        {"🔍 Conversation Depth", "Quick Conversations %", "Single-turn (1 prompt). 75-80% of all sessions. Efficient one-shot answers.", 25, 2502},
				        {"🔍 Conversation Depth", "Iterative Conversations %", "2-4 turn conversations. Normal working sessions with refinement.", 25, 2503},
				        {"🔍 Conversation Depth", "Deep Conversations %", "5+ turn conversations. Most common in Outlook (21%) and Teams meetings (34%).", 25, 2504},
				
				        {"🎯 Producing Drill-Down", "Specialists Delegated To", "Distinct specialist roles AI is filling in Producing mode (e.g. Data Analyst, Software Engineer, Compliance Specialist).", 26, 2601},
				        {"🎯 Producing Drill-Down", "Specialist FTE Equivalent", "Annualised FTE of specialist-grade work AI is performing. Human Equivalent Hours with Expertise_Role * 12 / 2080.", 26, 2602},
				        {"🎯 Producing Drill-Down", "Specialist Delegation Rate", "% of all users who have accessed specialist AI expertise. Measures how many people are delegating complex work to AI.", 26, 2603},
				        {"🎯 Producing Drill-Down", "Avg Specialisms Per User", "Average number of distinct specialist roles each user leverages. Higher = broader delegation.", 26, 2604},
				        {"🎯 Producing Drill-Down", "Role FTE Equivalent", "FTE equivalent per specialist role. Shows 0.8 FTE Data Analyst, 0.5 FTE Software Engineer, etc.", 26, 2605},
				
				        {"💡 Value Stories", "1 - Time Saved", "How much faster are we? Universal metric — every AI interaction saves time. Measured in Human Equivalent Hours (research-sourced baselines per behavior). Use: Efficiency - Hours Saved, Hours Per User Per Week.", 27, 2701},
				        {"💡 Value Stories", "2 - Work Created", "What is AI producing? Interactions in Producing mode that generate tangible output — documents, emails, presentations, code, data analysis, workflows, specialist agent work. Use: Work Created - Jobs, Per Week, Hours.", 27, 2702},
				        {"💡 Value Stories", "3 - Expertise Unlocked", "What specialist capabilities are users accessing? AI acting as Data Analyst, Software Engineer, Compliance Specialist, etc. Only genuinely specialist roles (not basic content creation). Use: New Expertise - Roles, FTEs, Users.", 27, 2703},
				        {"💡 Value Stories", "AI Tasks", "Total AI tasks completed (resource-level). Each resource accessed per prompt = one task. Higher than prompt count because multi-resource interactions are expanded. The primary what-AI-did metric — replaces sessions/prompts.", 27, 2704},
				        {"💡 Value Stories", "Tasks Per Prompt", "AI amplification factor. How many distinct tasks AI completes per user prompt. 1.0 = simple single-resource interaction. 2+ = multi-step orchestration.", 27, 2705},
				        {"💡 Value Stories", "Work Created - Rate", "% of all AI interactions that produce work (Producing mode). The maturity signal: higher = more productive AI usage.", 27, 2706},
				        {"💡 Value Stories", "Top Value Outcome", "The value outcome category with the most human equivalent hours saved. Dynamic to filters — changes based on date/org/environment selection.", 27, 2709},
				        {"💡 Value Stories", "AI Assisted Value", "Dollar value of AI work: Human Equivalent Hours x Hourly Value x Penalty Factor. All three inputs adjustable via slicers.", 27, 2710},
				        {"💡 Value Stories", "Copilot ROI", "AI Assisted Value / Copilot License Investment. >1x = positive return. Works with Environment filter for Copilot-only or Agent-only ROI.", 27, 2711},
				        {"💡 Value Stories", "Model Transparency", "DEEP_LEO = primary GPT-4 class model for conversational Copilot. REASONING_MODEL = chain-of-thought model for complex queries (1-2% of interactions). 30-47% of interactions have no model logged (embedded app features).", 27, 2712},
				        {"💡 Value Stories", "Expertise_Role", "Specialist role AI is acting as. Only genuinely specialist capabilities: Data Analyst, Software Engineer, Business Analyst, Compliance Specialist, Sales Consultant, IT Specialist, HR Specialist, Coach, Automation Engineer, Domain Expert.", 27, 2707},
				        {"💡 Value Stories", "Impact Summary", "Dynamic text combining all 3 value stories: hours saved + work items created + specialist roles unlocked.", 27, 2708}
					    }
					)

