	hierarchy 'Value_Outcome Hierarchy'
		lineageTag: 32c2c649-b74e-4956-bff7-559d24a67fd9

		level Value_Outcome
			lineageTag: 97e316e7-d38e-4173-bae1-33318dff2696
			column: Value_Outcome

		level Behavior
			lineageTag: c1d964dc-0f31-4e8e-b174-bc0b9fcd6e2d
			column: Behavior_Enriched_Full

	partition 'Chat + Agent Interactions (Audit Logs)' = m
		mode: import
		source =
				let
				    // Pre-parsed audit log: data is already JSON-parsed and fanned out to one row per
				    // (prompt x resource). No JSON parsing, ExpandRecordColumn or ExpandListColumn needed.
				    // Heavy work moved upstream (script / dataflow / Fabric pipeline).
				    // SharePoint URL only — local paths are deliberately not supported on this variant
				    // because they fail in Service refresh and the dual Web/File pattern can trigger
				    // Formula.Firewall during static analysis.
				    FilePath = #"Copilot Interactions File",
				    Source = Csv.Document(Web.Contents(FilePath), [Delimiter = ",", Encoding = 65001, QuoteStyle = QuoteStyle.Csv]),
				    #"Promoted Headers" = Table.PromoteHeaders(Source, [PromoteAllScalars = true]),
				
				    // ---- Pre-parsed variant: adapts Alex's current export script ---------------------
				    // The script flattens top-level audit fields but keeps these as JSON-strings:
				    //   AccessedResources : JSON array of resource objects
				    //   AISystemPlugin    : JSON object (or array) of plugin metadata
				    // It also doesn't emit a few canonical columns. We synthesise / parse them here
				    // so downstream measures see the same shape as the pre-parsed canonical schema.
				    #"Add Message_isPrompt"        = Table.AddColumn(#"Promoted Headers",        "Message_isPrompt",                    each "TRUE", type text),
				    #"Add ApplicationName"         = Table.AddColumn(#"Add Message_isPrompt",     "ApplicationName",                     each null, type text),
				    #"Add Audit_UserKey"           = Table.AddColumn(#"Add ApplicationName",      "Audit_UserKey",                       each null, type text),
				    #"Add SensitivityLabelId"      = Table.AddColumn(#"Add Audit_UserKey",        "SensitivityLabelId",                  each null, type text),
				    #"Add AR_SensLabel"            = Table.AddColumn(#"Add SensitivityLabelId",   "AccessedResource_SensitivityLabelId", each null, type text),
				
				    // Split the flat AppIdentity column (always a string in this export) into _AppId / _DisplayName.
				    #"Add AppIdentity_AppId"       = Table.AddColumn(#"Add AR_SensLabel",          "AppIdentity_AppId",       each null, type text),
				    #"Add AppIdentity_DisplayName" = Table.AddColumn(#"Add AppIdentity_AppId",    "AppIdentity_DisplayName", each try Text.From([AppIdentity]) otherwise null, type text),
				    #"Drop AppIdentity"            = Table.RemoveColumns(#"Add AppIdentity_DisplayName", {"AppIdentity"}, MissingField.Ignore),
				
				    // Parse AccessedResources JSON-string and explode to one row per resource.
				    #"Parse AR" = Table.AddColumn(#"Drop AppIdentity", "_resources", each
				        let
				            raw    = [AccessedResources],
				            parsed = if raw = null or raw = "" then null else try Json.Document(raw) otherwise null,
				            asList = if parsed is list then parsed
				                     else if parsed is record then {parsed}
				                     else {[Type = null, Action = null, SiteUrl = null]},
				            safe   = if List.Count(asList) > 0 then asList else {[Type = null, Action = null, SiteUrl = null]}
				        in safe),
				    #"Drop AR Original" = Table.RemoveColumns(#"Parse AR", {"AccessedResources"}, MissingField.Ignore),
				    #"Expand AR Rows"   = Table.ExpandListColumn(#"Drop AR Original", "_resources"),
				    #"Expand AR Cols"   = Table.ExpandRecordColumn(#"Expand AR Rows", "_resources",
				        {"Type", "Action", "SiteUrl"},
				        {"AccessedResource_Type", "AccessedResource_Action", "AccessedResource_SiteUrl"}),
				
				    // Parse AISystemPlugin JSON-string. Handle both single-object and array forms.
				    #"Parse Plugin" = Table.AddColumn(#"Expand AR Cols", "_plugin", each
				        let
				            raw    = [AISystemPlugin],
				            parsed = if raw = null or raw = "" then null else try Json.Document(raw) otherwise null,
				            single = if parsed is list and List.Count(parsed) > 0 then parsed{0}
				                     else if parsed is record then parsed
				                     else [Id = null, Name = null]
				        in single),
				    #"Drop Plugin Original" = Table.RemoveColumns(#"Parse Plugin", {"AISystemPlugin"}, MissingField.Ignore),
				    #"Expand Plugin"        = Table.ExpandRecordColumn(#"Drop Plugin Original", "_plugin",
				        {"Id", "Name"},
				        {"AISystemPlugin_Id", "AISystemPlugin_Name"}),
				    // ---- end Pre-parsed variant adaptations ----------------------------------------
				
				    // Type CreationDate (ISO-8601) explicitly with en-US culture for locale safety.
				    #"Typed CreationDate" = Table.TransformColumnTypes(#"Expand Plugin", {{"CreationDate", type datetime}}, "en-US"),
				
				    // Recompute date-derived columns from typed CreationDate (don't trust DD/MM text formats).
				    #"Drop Existing Date Cols" = Table.RemoveColumns(#"Typed CreationDate", {"InteractionDate", "WeekStart", "MonthStart"}, MissingField.Ignore),
				    #"Add InteractionDate" = Table.AddColumn(#"Drop Existing Date Cols", "InteractionDate", each try DateTime.Date([CreationDate]) otherwise null, type date),
				    #"Add WeekStart" = Table.AddColumn(#"Add InteractionDate", "WeekStart", each try Date.StartOfWeek([InteractionDate], Day.Monday) otherwise null, type date),
				    #"Add MonthStart" = Table.AddColumn(#"Add WeekStart", "MonthStart", each try Date.StartOfMonth([InteractionDate]) otherwise null, type date),
				
				    // Resource_Count: preserve from the parsed CSV if present (real per-event fan-out count),
				    // otherwise default each row to 1 (data assumed already fanned out at row level).
				    #"Add Resource Count" =
				        if Table.HasColumns(#"Add MonthStart", "Resource_Count")
				        then Table.TransformColumnTypes(#"Add MonthStart", {{"Resource_Count", Int64.Type}})
				        else Table.AddColumn(#"Add MonthStart", "Resource_Count", each 1, Int64.Type),
				
				    // Normalise UPN for the licensed-user merge if not already provided.
				    #"Normalize UPN" = Table.AddColumn(#"Add Resource Count", "_NormUPN", each
				        if Table.HasColumns(#"Add Resource Count", "Audit_UserId_Normalized")
				        then [Audit_UserId_Normalized]
				        else try Text.Lower(Text.Trim(Text.From([Audit_UserId]))) otherwise null,
				        type text),
				
				    // Merge Copilot Licenses info (LeftOuter so missing licenses don't drop rows).
				    #"Merged Licenses" = Table.NestedJoin(#"Normalize UPN", {"_NormUPN"}, #"Copilot Licensed", {"UPN_Normalized"}, "LicenseInfo", JoinKind.LeftOuter),
				    #"Expanded License" = Table.ExpandTableColumn(#"Merged Licenses", "LicenseInfo", {"Has license"}, {"Has license"}),
				
				    #"Final" = Table.RemoveColumns(#"Expanded License", {"_NormUPN", "Audit_UserId_Normalized"}, MissingField.Ignore)
				in
				    #"Final"

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

