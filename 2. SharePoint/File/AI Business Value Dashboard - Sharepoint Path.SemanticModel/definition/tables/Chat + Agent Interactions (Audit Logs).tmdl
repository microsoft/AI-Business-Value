		lineageTag: ff030001-0001-0001-0001-000000000113

	/// Users accessing specialist capabilities
	measure 'New Expertise - Users' =
			CALCULATE(
			    DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			    'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
			    NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[Expertise_Role]))
			)
		formatString: #,##0
		displayFolder: AI Fluency\4 - New Expertise
		lineageTag: ff030001-0001-0001-0001-000000000115

	/// Expert hours delivered per week (org total)
	measure 'New Expertise - Hours Per Week' =
			VAR TotalHrs = CALCULATE([Human Equivalent Hours], NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[Expertise_Role])))
			VAR Weeks = DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[WeekStart])
			RETURN DIVIDE(TotalHrs, Weeks, 0)
		formatString: #,##0.0
		displayFolder: AI Fluency\4 - New Expertise
		lineageTag: ff030001-0001-0001-0001-000000000116

	/// ════════════════════════════════════════════
	/// VALUE STORY 1: TIME SAVED (all interactions — everything saves time)
	/// "How much faster are we?" — universal metric across every interaction
	/// ════════════════════════════════════════════
	/// Total hours saved across ALL interactions
	measure 'Efficiency - Hours Saved' = [Human Equivalent Hours]
		formatString: #,##0.0
		displayFolder: AI Fluency\1 - Efficiency
		lineageTag: ff030001-0001-0001-0001-000000000100

	/// Hours saved per active user per active week
	measure 'Efficiency - Hours Per User Per Week' =
			AVERAGEX(
			    VALUES('Chat + Agent Interactions (Audit Logs)'[WeekStart]),
			    DIVIDE([Human Equivalent Hours], DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]), 0)
			)
		formatString: #,##0.0
		displayFolder: AI Fluency\1 - Efficiency
		lineageTag: ff030001-0001-0001-0001-000000000101

	/// Hours saved per week (org total)
	measure 'Efficiency - Hours Per Week' = DIVIDE([Human Equivalent Hours], DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[WeekStart]), 0)
		formatString: 0.00
		displayFolder: AI Fluency\1 - Efficiency
		lineageTag: ff030001-0001-0001-0001-000000000102

	/// Hours saved label "Xh Ym"
	measure 'Efficiency - Label' =
			VAR Hrs = [Efficiency - Hours Per User Per Week]
			VAR WholeHours = INT(Hrs)
			VAR Mins = ROUND((Hrs - WholeHours) * 60, 0)
			RETURN IF(WholeHours > 0, FORMAT(WholeHours, "0") & "h " & FORMAT(Mins, "0") & "m", FORMAT(Mins, "0") & "m")
		displayFolder: AI Fluency\1 - Efficiency
		lineageTag: ff030001-0001-0001-0001-000000000103

	/// Work items created per week (org total)
	measure 'Work Created - Per Week' =
			DIVIDE(
			    CALCULATE(COUNTROWS('Chat + Agent Interactions (Audit Logs)'), 'Chat + Agent Interactions (Audit Logs)'[Usage_Mode] IN {"4 - Producing"}),
			    DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[WeekStart]),
			    0
			)
		formatString: #,##0
		displayFolder: AI Fluency\2 - Work Created
		lineageTag: ff030001-0001-0001-0001-000000000106

	/// Specialist roles active
	measure 'New Expertise - Roles' =
			CALCULATE(
			    DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Expertise_Role]),
			    'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
			    NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[Expertise_Role]))
			)
		formatString: #,##0
		displayFolder: AI Fluency\4 - New Expertise
		lineageTag: ff030001-0001-0001-0001-000000000114

	/// Beginner users active this week
	measure 'Beginner Users (Weekly)' =
			CALCULATE(
			    DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			    'Chat + Agent Interactions (Audit Logs)'[User_Stage_Maturity] = "1 - Beginner"
			)
		formatString: #,##0
		displayFolder: AI Fluency\Maturity Score
		lineageTag: ff030001-0001-0001-0001-000000000131

	/// Developing users active this week
	measure 'Developing Users (Weekly)' =
			CALCULATE(
			    DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			    'Chat + Agent Interactions (Audit Logs)'[User_Stage_Maturity] = "2 - Developing"
			)
		formatString: #,##0
		displayFolder: AI Fluency\Maturity Score
		lineageTag: ff030001-0001-0001-0001-000000000132

	/// Proficient users active this week
	measure 'Proficient Users (Weekly)' =
			CALCULATE(
			    DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			    'Chat + Agent Interactions (Audit Logs)'[User_Stage_Maturity] = "3 - Proficient"
			)
		formatString: #,##0
		displayFolder: AI Fluency\Maturity Score
		lineageTag: ff030001-0001-0001-0001-000000000133

	/// Total AI actions performed by agents (Agent Value Tracker — no Environment filter needed)
	measure 'Agent AI Tasks' = CALCULATE(COUNTROWS('Chat + Agent Interactions (Audit Logs)'), NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentId])))
		formatString: #,##0
		displayFolder: AI Fluency\Agents - Value
		lineageTag: ff030001-0001-0001-0001-000000000139

	/// Agent AI actions per user per week (both sides filtered to agent rows)
	measure 'Agent AI Tasks Per User Per Week' =
			AVERAGEX(
			    CALCULATETABLE(VALUES('Chat + Agent Interactions (Audit Logs)'[WeekStart]), NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentId]))),
			    DIVIDE(
			        CALCULATE(COUNTROWS('Chat + Agent Interactions (Audit Logs)'), NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentId]))),
			        CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]), NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentId]))),
			        0
			    )
			)
		formatString: #,##0.0
		displayFolder: AI Fluency\Agents - Value
		lineageTag: ff030001-0001-0001-0001-000000000140

	/// Agent AI actions per week — any activity delivered by any agent
	/// (Studio agents, declarative agents, Logic Apps, autonomous flows).
	/// Counts rows where Environment is "Agents" OR "Autonomous Agent" so
	/// agent-delivered activity that lacks an AgentId GUID still contributes.
	measure 'Agent AI Tasks Per Week' =
			VAR AgentRows = FILTER(
			    'Chat + Agent Interactions (Audit Logs)',
			    'Chat + Agent Interactions (Audit Logs)'[Environment] IN {"Agents", "Autonomous Agent"}
			)
			RETURN
			DIVIDE(
			    COUNTROWS(AgentRows),
			    CALCULATE(
			        DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[WeekStart]),
			        'Chat + Agent Interactions (Audit Logs)'[Environment] IN {"Agents", "Autonomous Agent"}
			    ),
			    0
			)
		formatString: #,##0
		displayFolder: AI Fluency\Agents - Value
		lineageTag: ff030001-0001-0001-0001-000000000141

	/// Total Copilot AI actions (Copilot Value Tracker — no Environment filter needed)
	measure 'Copilot AI Tasks' = CALCULATE(COUNTROWS('Chat + Agent Interactions (Audit Logs)'), 'Chat + Agent Interactions (Audit Logs)'[Environment] = "Licensed M365 Copilot")
		formatString: #,##0
		displayFolder: AI Fluency\Copilot - Value
		lineageTag: ff030001-0001-0001-0001-000000000154

	/// Copilot AI actions per user per week
	measure 'Copilot AI Tasks Per User Per Week' =
			AVERAGEX(
			    CALCULATETABLE(VALUES('Chat + Agent Interactions (Audit Logs)'[WeekStart]), 'Chat + Agent Interactions (Audit Logs)'[Environment] = "Licensed M365 Copilot"),
			    DIVIDE(
			        CALCULATE(COUNTROWS('Chat + Agent Interactions (Audit Logs)'), 'Chat + Agent Interactions (Audit Logs)'[Environment] = "Licensed M365 Copilot"),
			        CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]), 'Chat + Agent Interactions (Audit Logs)'[Environment] = "Licensed M365 Copilot"),
			        0
			    )
			)
		formatString: #,##0.0
		displayFolder: AI Fluency\Copilot - Value
		lineageTag: ff030001-0001-0001-0001-000000000155

	/// Copilot AI actions per week
	measure 'Copilot AI Tasks Per Week' =
			DIVIDE(
			    CALCULATE(COUNTROWS('Chat + Agent Interactions (Audit Logs)'), 'Chat + Agent Interactions (Audit Logs)'[Environment] = "Licensed M365 Copilot"),
			    CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[WeekStart]), 'Chat + Agent Interactions (Audit Logs)'[Environment] = "Licensed M365 Copilot"),
			    0
			)
		formatString: #,##0
		displayFolder: AI Fluency\Copilot - Value
		lineageTag: ff030001-0001-0001-0001-000000000156

	/// Copilot users (licensed)
	measure 'Copilot Users' = CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]), 'Chat + Agent Interactions (Audit Logs)'[Environment] = "Licensed M365 Copilot")
		formatString: #,##0
		displayFolder: AI Fluency\Copilot - Value
		lineageTag: ff030001-0001-0001-0001-000000000160

	/// Copilot tasks per active Copilot user (entire period)
	measure 'Copilot AI Tasks Per User' =
			DIVIDE(
			    [Copilot AI Tasks],
			    [Copilot Users],
			    0
			)
		formatString: #,##0.0
		displayFolder: AI Fluency\Copilot - Value
		lineageTag: ff030001-0001-0001-0001-000000000162

	/// Agent tasks per active agent user (entire period)
	measure 'Agent AI Tasks Per User' =
			DIVIDE(
			    [Agent AI Tasks],
			    [Agent Users],
			    0
			)
		formatString: #,##0.0
		displayFolder: AI Fluency\Agents - Value
		lineageTag: ff030001-0001-0001-0001-000000000163

	/// Total AI tasks by unlicensed chat users (Unlicensed Value Tracker — no Environment filter needed)
	measure 'Unlicensed AI Tasks' = CALCULATE(COUNTROWS('Chat + Agent Interactions (Audit Logs)'), 'Chat + Agent Interactions (Audit Logs)'[Environment] = "Unlicensed Chat")
		formatString: #,##0
		displayFolder: AI Fluency\Unlicensed - Value
		lineageTag: ff030001-0001-0001-0001-000000000164

	/// Unlicensed AI tasks per user per week (only active unlicensed users)
	measure 'Unlicensed AI Tasks Per User Per Week' =
			AVERAGEX(
			    CALCULATETABLE(VALUES('Chat + Agent Interactions (Audit Logs)'[WeekStart]), 'Chat + Agent Interactions (Audit Logs)'[Environment] = "Unlicensed Chat"),
			    DIVIDE(
			        CALCULATE(COUNTROWS('Chat + Agent Interactions (Audit Logs)'), 'Chat + Agent Interactions (Audit Logs)'[Environment] = "Unlicensed Chat"),
			        CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]), 'Chat + Agent Interactions (Audit Logs)'[Environment] = "Unlicensed Chat"),
			        0
			    )
			)
		formatString: #,##0.0
		displayFolder: AI Fluency\Unlicensed - Value
		lineageTag: ff030001-0001-0001-0001-000000000165

	/// Unlicensed tasks per active user (entire period)
	measure 'Unlicensed AI Tasks Per User' =
			DIVIDE(
			    [Unlicensed AI Tasks],
			    CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]), 'Chat + Agent Interactions (Audit Logs)'[Environment] = "Unlicensed Chat"),
			    0
			)
		formatString: #,##0.0
		displayFolder: AI Fluency\Unlicensed - Value
		lineageTag: ff030001-0001-0001-0001-000000000167

	/// AI Assisted Value: Hours x Hourly Value x Penalty Factor (all adjustable via slicers)
	measure 'AI Assisted Value' = [Human Equivalent Hours] * [Hourly Value Value] * [Penalty Factor Value]
		formatString: $#,##0
		displayFolder: AI Fluency\ROI
		lineageTag: ff0b0001-0001-0001-0001-000000000020

	/// Copilot License Investment: PPUPM x Licensed Users x Months (fixed cost regardless of filter)
	measure 'Copilot License Investment' =
			SUMX(
			    VALUES('Chat + Agent Interactions (Audit Logs)'[MonthStart]),
			    [AI PPUPM Value] *
			    CALCULATE(
			        DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			        'Chat + Agent Interactions (Audit Logs)'[License Status] = "M365 Copilot Licensed"
			    )
			)
		formatString: $#,##0
		displayFolder: AI Fluency\ROI
		lineageTag: ff0b0001-0001-0001-0001-000000000022

	/// Top Value Outcome by hours saved (dynamic to filters)
	measure 'Top Value Outcome' =
			MAXX(
			    TOPN(1,
			        ADDCOLUMNS(
			            VALUES('Chat + Agent Interactions (Audit Logs)'[Value_Outcome]),
			            "@Hrs", [Human Equivalent Hours]
			        ),
			        [@Hrs], DESC
			    ),
			    'Chat + Agent Interactions (Audit Logs)'[Value_Outcome]
			)
		displayFolder: AI Fluency\1 - Efficiency
		lineageTag: ff030001-0001-0001-0001-000000000175

	measure 'AI Assisted Value Per Week' =
			
			DIVIDE(
			    [AI Assisted Value],
			    DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[WeekStart]),
			    0
			)
		formatString: $#,##0
		displayFolder: AI Fluency\ROI
		lineageTag: 2769b48a-57a1-4acb-8a8b-6e3d70626ad7

		annotation PBI_FormatHint = {"isCustom":true}

	/// Projected annualised value at current adoption (observed value scaled from visible weeks to 52)
	measure 'Projected Annualised Value' =
			VAR WeeksInView = DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[WeekStart])
			VAR AnnualFactor = DIVIDE(52, MAX(WeeksInView, 1), 0)
			RETURN [AI Assisted Value] * AnnualFactor
		formatString: $#,##0
		displayFolder: AI Fluency\Functional Value
		lineageTag: ff0c0001-0001-0001-0001-000000000044

	/// Autonomy Mix: % of hours saved where humans used Copilot directly (Pattern 1 - Human uses Copilot)
	measure 'Copilot Mix %' =
			DIVIDE(
			    CALCULATE([Human Equivalent Hours], 'Chat + Agent Interactions (Audit Logs)'[Environment] = "Licensed M365 Copilot"),
			    [Human Equivalent Hours],
			    0
			)
		formatString: 0.0%
		displayFolder: AI Fluency\Autonomy Mix
		lineageTag: ff0d0001-0001-0001-0001-000000000001

	/// Autonomy Mix: % of hours saved where humans worked alongside an agent (Pattern 2 - Human uses agent, reviews & approves)
	measure 'Agent-Assisted Mix %' =
			DIVIDE(
			    CALCULATE([Human Equivalent Hours], 'Chat + Agent Interactions (Audit Logs)'[Environment] = "Agents"),
			    [Human Equivalent Hours],
			    0
			)
		formatString: 0.0%
		displayFolder: AI Fluency\Autonomy Mix
		lineageTag: ff0d0001-0001-0001-0001-000000000002

	/// Autonomy Mix: % of hours saved where agents ran workflows autonomously (Pattern 3 - Humans set direction, agents operate)
	measure 'Agent-Autonomous Mix %' =
			DIVIDE(
			    CALCULATE([Human Equivalent Hours], 'Chat + Agent Interactions (Audit Logs)'[Environment] = "Autonomous Agent"),
			    [Human Equivalent Hours],
			    0
			)
		formatString: 0.0%
		displayFolder: AI Fluency\Autonomy Mix
		lineageTag: ff0d0001-0001-0001-0001-000000000003

	measure 'User % (by pattern)' =
			
			DIVIDE(
			    DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			    CALCULATE(
			        DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			        ALL('Chat + Agent Interactions (Audit Logs)'[Autonomy_Pattern])
			    ),
			    0
			)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: AI Fluency
		lineageTag: a70c9c91-1f55-4d79-abbb-2b32f16485d9

	/// Beginner Users % (of all active users in this period)
	measure 'Beginner Users %' = DIVIDE([Beginner Users], [All Active Users], 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: AI Fluency\User Stages
		lineageTag: ff020001-0001-0001-0001-000000000306

	/// Developing Users % (of all active users in this period)
	measure 'Developing Users %' = DIVIDE([Developing Users], [All Active Users], 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: AI Fluency\User Stages
		lineageTag: ff020001-0001-0001-0001-000000000307

	/// AI ROI Multiple: AI Assisted Value ÷ Copilot License Investment. Dynamic to all filters.
	measure 'AI ROI' = DIVIDE([AI Assisted Value], [Copilot License Investment], 0)
		formatString: 0.00"x"
		displayFolder: AI Fluency\ROI
		lineageTag: ff0b0001-0001-0001-0001-000000000030

	/// Net ROI ($): AI Assisted Value minus Copilot License Investment (dollar benefit after cost)
	measure 'Net ROI ($)' = [AI Assisted Value] - [Copilot License Investment]
		formatString: $#,##0
		displayFolder: AI Fluency\ROI
		lineageTag: ff0b0001-0001-0001-0001-000000000031

	measure 'Activity Share' = ```
			
			    DIVIDE(
			        CALCULATE(
			            COUNTROWS('Chat + Agent Interactions (Audit Logs)'),
			            'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE"
			        ),
			        CALCULATE(
			            COUNTROWS('Chat + Agent Interactions (Audit Logs)'),
			            'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
			            REMOVEFILTERS(
			                'Chat + Agent Interactions (Audit Logs)'[Usage_Mode],
			                'Chat + Agent Interactions (Audit Logs)'[Behavior_Enriched_Full],
			                'Chat + Agent Interactions (Audit Logs)'[Behavior_Category],
			                'Chat + Agent Interactions (Audit Logs)'[Efficiency_Breakdown],
			                'Chat + Agent Interactions (Audit Logs)'[Value_Outcome],
			                'Chat + Agent Interactions (Audit Logs)'[Expertise_Role]
			            )
			        ),
			        0
			    )
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: be5a75f5-b45a-4db7-a70f-8f67dd6ba89f

	/// Cowork AI actions (collaborative AI sessions — multi-user real-time)
	measure 'Cowork AI Tasks' =
			CALCULATE(
			    COUNTROWS('Chat + Agent Interactions (Audit Logs)'),
			    'Chat + Agent Interactions (Audit Logs)'[Environment] = "Cowork"
			)
		formatString: #,##0
		displayFolder: AI Fluency\Cowork - Value
		lineageTag: ff030001-0001-0001-0001-000000000170

	/// Cowork AI actions per week
	measure 'Cowork AI Tasks Per Week' =
			DIVIDE(
			    CALCULATE(
			        COUNTROWS('Chat + Agent Interactions (Audit Logs)'),
			        'Chat + Agent Interactions (Audit Logs)'[Environment] = "Cowork"
			    ),
			    CALCULATE(
			        DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[WeekStart]),
			        'Chat + Agent Interactions (Audit Logs)'[Environment] = "Cowork"
			    ),
			    0
			)
		formatString: #,##0
		displayFolder: AI Fluency\Cowork - Value
		lineageTag: ff030001-0001-0001-0001-000000000171

	/// Cowork users — distinct users with at least one Cowork interaction
	measure 'Cowork Users' =
			CALCULATE(
			    DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			    'Chat + Agent Interactions (Audit Logs)'[Environment] = "Cowork"
			)
		formatString: #,##0
		displayFolder: AI Fluency\Cowork - Value
		lineageTag: ff030001-0001-0001-0001-000000000172

	/// Cowork tasks per active Cowork user per active week
	measure 'Cowork AI Tasks Per User Per Week' =
			AVERAGEX(
			    CALCULATETABLE(
			        VALUES('Chat + Agent Interactions (Audit Logs)'[WeekStart]),
			        'Chat + Agent Interactions (Audit Logs)'[Environment] = "Cowork"
			    ),
			    DIVIDE(
			        CALCULATE(
			            COUNTROWS('Chat + Agent Interactions (Audit Logs)'),
			            'Chat + Agent Interactions (Audit Logs)'[Environment] = "Cowork"
			        ),
			        CALCULATE(
			            DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			            'Chat + Agent Interactions (Audit Logs)'[Environment] = "Cowork"
			        ),
			        0
			    )
			)
		formatString: #,##0.0
		displayFolder: AI Fluency\Cowork - Value
		lineageTag: ff030001-0001-0001-0001-000000000173

	/// Automating AI Rate: % of interactions in Usage_Mode "5 - Automating"
	/// (Workflow Execution, autonomous Copilot Studio agents, Logic Apps, etc.)
	measure 'Automating AI Rate' =
			VAR AutomatingCount =
			    CALCULATE(
			        COUNTROWS('Chat + Agent Interactions (Audit Logs)'),
			        'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
			        'Chat + Agent Interactions (Audit Logs)'[Usage_Mode] IN {"5 - Automating"}
			    )
			VAR TotalCount =
			    CALCULATE(
			        COUNTROWS('Chat + Agent Interactions (Audit Logs)'),
			        'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE"
			    )
			RETURN DIVIDE(AutomatingCount, TotalCount, 0)
		formatString: 0%;-0%;0%
		displayFolder: AI Fluency\Usage Modes
		lineageTag: ff030001-0001-0001-0001-000000000023

