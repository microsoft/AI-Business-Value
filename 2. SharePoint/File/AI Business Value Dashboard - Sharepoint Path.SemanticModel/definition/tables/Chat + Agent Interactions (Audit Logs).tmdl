	/// Dynamic ranking with current filters
	/// 📊 Updates with your selections
	/// 💡 Drill to see specific cohorts
	measure 'License Priority Rank (Dynamic)' =
			
			VAR CurrentScore = [License Priority Score (User)]
			VAR IsUserLevel = ISINSCOPE('Chat + Agent Interactions (Audit Logs)'[Audit_UserId])
			
			RETURN
			IF(
			    ISBLANK(CurrentScore),
			    BLANK(),
			    IF(
			        IsUserLevel,
			        // Rank users - ONLY those with unlicensed activity
			        RANKX(
			            FILTER(
			                ALLSELECTED('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			                CALCULATE(
			                    COUNTROWS('Chat + Agent Interactions (Audit Logs)'),
			                    'Chat + Agent Interactions (Audit Logs)'[License Status] = "Unlicensed"
			                ) > 0
			                && NOT(ISBLANK([License Priority Score (User)]))
			            ),
			            [License Priority Score (User)],
			            ,
			            DESC,
			            DENSE
			        ),
			        // Rank organizations - ONLY those with unlicensed users
			        RANKX(
			            FILTER(
			                ALLSELECTED('Chat + Agent Org Data'[Organization]),
			                CALCULATE(
			                    COUNTROWS('Chat + Agent Interactions (Audit Logs)'),
			                    'Chat + Agent Interactions (Audit Logs)'[License Status] = "Unlicensed"
			                ) > 0
			                && NOT(ISBLANK([License Priority Score (User)]))
			            ),
			            [License Priority Score (User)],
			            ,
			            DESC,
			            DENSE
			        )
			    )
			)
		formatString: 0
		lineageTag: d45ae6e2-c85c-41ff-99dc-7c4e4065c514

	/// Percentage of all active Copilot users who are also using agents
	/// 🎯 Target: 20-40%
	/// 💡 Higher % = strong agent discoverability and adoption
	measure 'Agent Adoption Rate' = ```
			VAR _AgentUsers = [UsersInteractingWithAgents]
			VAR _AllActiveUsers = 
			    CALCULATE(
			        COUNTROWS(
			            FILTER(
			                VALUES('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			                CALCULATE([PromptsSubmitted]) > 0
			            )
			        ),
			        ALL('Chat + Agent Interactions (Audit Logs)'[AgentId]),
			        ALL('Chat + Agent Interactions (Audit Logs)'[AgentName]),
			        ALL('Chat + Agent Interactions (Audit Logs)'[Context_Type]),
			        ALL('Chat + Agent Interactions (Audit Logs)'[Agent_TitleID])
			    )
			RETURN
			    DIVIDE(_AgentUsers, _AllActiveUsers, 0)
			```
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 6d870706-d5d2-4a0b-bfc4-ffd858519248

	/// Month-over-month % change in licensed user sessions. Positive = growth, negative = decline.
	measure 'Licensed Sessions MoM %' = ```
			VAR _Current = [Sessions (Licensed Users Only)]
			VAR _Previous = 
			    CALCULATE(
			        [Sessions (Licensed Users Only)],
			        DATEADD(Calendar[Date], -1, MONTH)
			    )
			RETURN
			    DIVIDE(_Current - _Previous, _Previous, BLANK())
			```
		formatString: +0.0%;-0.0%;0.0%
		displayFolder: 📈 Session Trends
		lineageTag: 52b866ef-cc4d-4c97-b0aa-d984f39a386c

	/// Month-over-month % change in unlicensed user sessions. Positive = growth, negative = decline.
	measure 'Unlicensed Sessions MoM %' = ```
			VAR _Current = [Sessions (Unlicensed Users Only)]
			VAR _Previous = 
			    CALCULATE(
			        [Sessions (Unlicensed Users Only)],
			        DATEADD(Calendar[Date], -1, MONTH)
			    )
			RETURN
			    DIVIDE(_Current - _Previous, _Previous, BLANK())
			```
		formatString: +0.0%;-0.0%;0.0%
		displayFolder: 📈 Session Trends
		lineageTag: da95b48f-ffc5-4cac-aebd-7eef5c686591

	/// Percentage of interactions involving sensitive data
	measure 'Interactions with Sensitive Data %' =
			VAR SensitiveCount = CALCULATE(COUNTROWS('Chat + Agent Interactions (Audit Logs)'), 'Chat + Agent Interactions (Audit Logs)'[Is_Sensitive] = TRUE)
			VAR TotalCount = COUNTROWS('Chat + Agent Interactions (Audit Logs)')
			RETURN DIVIDE(SensitiveCount, TotalCount, 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: AI Fluency\Behaviors\Modifiers
		lineageTag: ff020001-0001-0001-0001-0000000000c2

	/// User-facing AI task count: prompt rows only (excludes bot replies, traces,
	/// system events). What end-users would call "an AI interaction" — the input
	/// they sent. Used by Executive Headline and the Heatmap Toggle slicer label.
	measure 'AI Tasks' =
			CALCULATE(
			    COUNTROWS('Chat + Agent Interactions (Audit Logs)'),
			    'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE"
			)
		formatString: #,##0
		displayFolder: AI Fluency\Value Types
		lineageTag: ff030001-0001-0001-0001-000000000047

	/// Agent users
	measure 'Agent Users' = CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]), NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentId])))
		formatString: #,##0
		displayFolder: AI Fluency\Agents - Value
		lineageTag: ff030001-0001-0001-0001-000000000153

	/// All Active Users: Every unique user who has used Copilot or Agents (licensed + unlicensed)
	measure 'All Active Users' = DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId])
		formatString: #,##0
		displayFolder: AI Fluency\Adoption Funnel
		lineageTag: ff020001-0001-0001-0001-000000000204

	/// Beginner Users (this period): <3 behaviors OR <3 active days. Users just getting started.
	measure 'Beginner Users' =
			VAR UserStats =
			ADDCOLUMNS(
			VALUES('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			"Behaviors", CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Behavior_Category])),
			"HasAgent", CALCULATE(COUNTROWS(FILTER('Chat + Agent Interactions (Audit Logs)', NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentName])) && 'Chat + Agent Interactions (Audit Logs)'[AgentName] <> ""))) > 0,
			"ActiveDays", CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[InteractionDate]))
			)
			RETURN COUNTROWS(FILTER(UserStats, NOT([Behaviors] >= 3 && [ActiveDays] >= 3)))
		formatString: #,##0
		displayFolder: AI Fluency\User Stages
		lineageTag: ff020001-0001-0001-0001-000000000301

	/// Developing Users (this period): 3+ behaviors AND 3+ active days (but not Proficient). Consistent multi-workflow use.
	measure 'Developing Users' =
			VAR UserStats =
			ADDCOLUMNS(
			VALUES('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			"Behaviors", CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Behavior_Category])),
			"HasAgent", CALCULATE(COUNTROWS(FILTER('Chat + Agent Interactions (Audit Logs)', NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentName])) && 'Chat + Agent Interactions (Audit Logs)'[AgentName] <> ""))) > 0,
			"ActiveDays", CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[InteractionDate]))
			)
			RETURN COUNTROWS(FILTER(UserStats, [Behaviors] >= 3 && [ActiveDays] >= 3 && NOT([Behaviors] >= 5 && [ActiveDays] >= 8)))
		formatString: #,##0
		displayFolder: AI Fluency\User Stages
		lineageTag: ff020001-0001-0001-0001-000000000302

	/// Proficient Users (this period): 5+ behaviors AND 8+ active days. AI is habitual across many workflows.
	measure 'Proficient Users' =
			VAR UserStats =
			ADDCOLUMNS(
			VALUES('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			"Behaviors", CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Behavior_Category])),
			"HasAgent", CALCULATE(COUNTROWS(FILTER('Chat + Agent Interactions (Audit Logs)', NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentName])) && 'Chat + Agent Interactions (Audit Logs)'[AgentName] <> ""))) > 0,
			"ActiveDays", CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[InteractionDate]))
			)
			RETURN COUNTROWS(FILTER(UserStats, [Behaviors] >= 5 && [ActiveDays] >= 8))
		formatString: #,##0
		displayFolder: AI Fluency\User Stages
		lineageTag: ff020001-0001-0001-0001-000000000303

	/// Proficient Users % (of all active users in this period)
	measure 'Proficient Users %' = DIVIDE([Proficient Users], [All Active Users], 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: AI Fluency\User Stages
		lineageTag: ff020001-0001-0001-0001-000000000308

	/// % of active users at Proficient stage — quick maturity indicator for comparing groups
	measure 'Proficient Users % (of Active)' = DIVIDE([Proficient Users], [All Active Users], 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: AI Fluency\User Stages
		lineageTag: ff020001-0001-0001-0001-000000000311

	/// Rolling 4-week stage counts — for each week, looks back 4 weeks and assigns stage per user based on that window
	measure '4W Beginner Users' =
			VAR CurrentWeek = MAX('Chat + Agent Interactions (Audit Logs)'[WeekStart])
			VAR WindowStart = CurrentWeek - 21
			VAR UserStats =
			ADDCOLUMNS(
			CALCULATETABLE(
			    VALUES('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			    'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart,
			    'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= CurrentWeek,
			    'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE"
			),
			"Behaviors", CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Behavior_Category]), 'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= CurrentWeek),
			"HasAgent", CALCULATE(COUNTROWS(FILTER('Chat + Agent Interactions (Audit Logs)', NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentName])) && 'Chat + Agent Interactions (Audit Logs)'[AgentName] <> "")), 'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= CurrentWeek) > 0,
			"ActiveDays", CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[InteractionDate]), 'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= CurrentWeek)
			)
			VAR WithStage =
			ADDCOLUMNS(UserStats, "Stage",
			IF([Behaviors] >= 5 && [ActiveDays] >= 8, "Proficient",
			IF([Behaviors] >= 3 && [ActiveDays] >= 3, "Developing",
			"Beginner")))
			RETURN COUNTROWS(FILTER(WithStage, [Stage] = "Beginner"))
		formatString: #,##0
		displayFolder: AI Fluency\User Stages (4-Week Rolling)
		lineageTag: ff020001-0001-0001-0001-000000000501

	measure '4W Developing Users' =
			VAR CurrentWeek = MAX('Chat + Agent Interactions (Audit Logs)'[WeekStart])
			VAR WindowStart = CurrentWeek - 21
			VAR UserStats =
			ADDCOLUMNS(
			CALCULATETABLE(
			    VALUES('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			    'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart,
			    'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= CurrentWeek,
			    'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE"
			),
			"Behaviors", CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Behavior_Category]), 'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= CurrentWeek),
			"HasAgent", CALCULATE(COUNTROWS(FILTER('Chat + Agent Interactions (Audit Logs)', NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentName])) && 'Chat + Agent Interactions (Audit Logs)'[AgentName] <> "")), 'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= CurrentWeek) > 0,
			"ActiveDays", CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[InteractionDate]), 'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= CurrentWeek)
			)
			VAR WithStage =
			ADDCOLUMNS(UserStats, "Stage",
			IF([Behaviors] >= 5 && [ActiveDays] >= 8, "Proficient",
			IF([Behaviors] >= 3 && [ActiveDays] >= 3, "Developing",
			"Beginner")))
			RETURN COUNTROWS(FILTER(WithStage, [Stage] = "Developing"))
		formatString: #,##0
		displayFolder: AI Fluency\User Stages (4-Week Rolling)
		lineageTag: ff020001-0001-0001-0001-000000000502

	measure '4W Proficient Users' =
			VAR CurrentWeek = MAX('Chat + Agent Interactions (Audit Logs)'[WeekStart])
			VAR WindowStart = CurrentWeek - 21
			VAR UserStats =
			ADDCOLUMNS(
			CALCULATETABLE(
			    VALUES('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			    'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart,
			    'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= CurrentWeek,
			    'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE"
			),
			"Behaviors", CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Behavior_Category]), 'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= CurrentWeek),
			"HasAgent", CALCULATE(COUNTROWS(FILTER('Chat + Agent Interactions (Audit Logs)', NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentName])) && 'Chat + Agent Interactions (Audit Logs)'[AgentName] <> "")), 'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= CurrentWeek) > 0,
			"ActiveDays", CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[InteractionDate]), 'Chat + Agent Interactions (Audit Logs)'[WeekStart] >= WindowStart, 'Chat + Agent Interactions (Audit Logs)'[WeekStart] <= CurrentWeek)
			)
			VAR WithStage =
			ADDCOLUMNS(UserStats, "Stage",
			IF([Behaviors] >= 5 && [ActiveDays] >= 8, "Proficient",
			IF([Behaviors] >= 3 && [ActiveDays] >= 3, "Developing",
			"Beginner")))
			RETURN COUNTROWS(FILTER(WithStage, [Stage] = "Proficient"))
		formatString: #,##0
		displayFolder: AI Fluency\User Stages (4-Week Rolling)
		lineageTag: ff020001-0001-0001-0001-000000000503

	/// Stage Profile: Top org for current stage context
	measure 'Stage Top Org' =
			VAR OrgTable =
			    ADDCOLUMNS(
			        VALUES('Chat + Agent Org Data'[Organization]),
			        "UserCount",
			        CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]))
			    )
			VAR TopRow = TOPN(1, OrgTable, [UserCount], DESC)
			RETURN MAXX(TopRow, 'Chat + Agent Org Data'[Organization])
		displayFolder: AI Fluency\Stage Profiles
		lineageTag: ff020001-0001-0001-0001-000000000602

	/// Total human-equivalent hours: what AI is handling that humans would otherwise do
	/// Sources: McKinsey 2023, NBER (Brynjolfsson/Noy&Zhang), BCG/Harvard, Forrester TEI 2024
	measure 'Human Equivalent Hours' =
			SUMX(
			    FILTER(
			        'Chat + Agent Interactions (Audit Logs)',
			        'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE"
			    ),
			    DIVIDE(
			        RELATED('Human Time Estimates'[Human Baseline (min)]),
			        60,
			        0
			    )
			)
		formatString: #,##0.0
		displayFolder: AI Fluency\Time Savings
		lineageTag: ff060001-0001-0001-0001-000000000010

	/// Estimated hours saved (30% efficiency gain — Noy & Zhang, Science 2023)
	measure 'Estimated Hours Saved' = [Human Equivalent Hours] * 0.70
		formatString: #,##0.0
		displayFolder: AI Fluency\Time Savings
		lineageTag: ff060001-0001-0001-0001-000000000011

	/// Average augmented skills per user
	measure 'Avg Skills Per User' = ```
			
			    AVERAGEX(
			        VALUES('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			        CALCULATE(
			            DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Behavior_Category]),
			            'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE"
			        )
			    )
