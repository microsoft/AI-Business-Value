table 'Chat + Agent Interactions (Audit Logs)'
	lineageTag: be471a18-81ce-45e7-8166-531a052df5d5

	/// Total Copilot prompts submitted
	/// 📈 Volume indicator
	/// 💡 Track growth and trends
	measure PromptsSubmitted = CALCULATE(DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Message_Id]),'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE")
		formatString: 0
		lineageTag: aa0e8e7e-5e3d-4709-9a73-95cc9be8cd3f

		changedProperty = IsHidden

	/// Users interacting with Copilot agents
	/// 🎯 Target: 20-40% of Chat users
	/// 💡 Higher % = good agent discoverability
	measure UsersInteractingWithAgents =
			-- Counts users of any agent activity: registered agents (have AgentId)
			-- AND autonomous Copilot Studio flows (have Environment="Autonomous Agent"
			-- but blank AgentId). Without the Environment branch, autonomous agents
			-- show zero users and get filtered out of leaderboards.
			CALCULATE(
			    DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			    'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
			    'Chat + Agent Interactions (Audit Logs)'[Environment] IN {"Agents", "Autonomous Agent"}
			)
		formatString: 0
		lineageTag: 520169a7-8b60-47b3-8c29-548dba3d469d

		changedProperty = IsHidden

	measure 'UsersInteractingWithAgents, Last Month' =
			
			VAR MaxDate = CALCULATE(MAX('Chat + Agent Interactions (Audit Logs)'[CreationDate]), ALL('Chat + Agent Interactions (Audit Logs)'))
			VAR LastMonthStart = EOMONTH(MaxDate, -2) + 1
			VAR Result =
			    CALCULATE(
			        DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			        'Chat + Agent Interactions (Audit Logs)'[MonthStart] = LastMonthStart,
			        'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
			        NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentId]))
			    )
			RETURN Result + 0
		formatString: 0
		lineageTag: 83163a0e-084f-40d7-b612-83a374053e40

		changedProperty = IsHidden

	measure _MaxDate = MAX('Chat + Agent Interactions (Audit Logs)'[CreationDate])
		formatString: General Date
		lineageTag: 8b3aa008-cd02-47e9-88e6-ec53ea7662ea

		changedProperty = IsHidden

	measure _LastMonthStart = EOMONTH([_MaxDate], -2) + 1
