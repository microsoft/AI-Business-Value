	/// User maturity stage — now a single RELATED lookup against UserMonthMetrics[UserStage]
	/// (pre-computed once per user-month instead of per-row CALCULATETABLE).
	column User_Stage_Maturity = RELATED('UserMonthMetrics'[UserStage])
		dataType: string
