	/// Monthly avg actions per user
	/// 📊 Monthly usage intensity
	/// 💡 Benchmark across departments
	measure 'AverageActionsPerUserPerMonth (Licensed Copilot Only)' = ```
			
			
			AVERAGEX(
			    VALUES('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			    VAR TotalPrompts =
			        CALCULATE(
			            DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Message_Id]),
			            'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
			            ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentId]),  -- Excludes Agents
			            'Chat + Agent Interactions (Audit Logs)'[License Status] = "M365 Copilot Licensed",
			            ALL('Chat + Agent Interactions (Audit Logs)'[MonthStart])
			        )
			    VAR TotalMonths =
			        CALCULATE(
			            DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[MonthStart]),
			            'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
			            ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentId]),
			            'Chat + Agent Interactions (Audit Logs)'[License Status] = "M365 Copilot Licensed",
			            ALL('Chat + Agent Interactions (Audit Logs)'[MonthStart])
			        )
			    RETURN
			        DIVIDE(TotalPrompts, TotalMonths, 0)
			)
			
