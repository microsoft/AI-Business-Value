	/// User using most different agents
	/// 🌟 Power user exploring broadly
	/// 💡 Early adopter of new agents
	measure 'Most Versatile Agent' = ```
			
			VAR AgentUserCounts = 
			    ADDCOLUMNS(
			        SUMMARIZE(
			            'Chat + Agent Interactions (Audit Logs)',
			            'Chat + Agent Interactions (Audit Logs)'[AgentName]
			        ),
			        "@UniqueUsers", 
			        CALCULATE(
			            DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			            'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
			            NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentId]))
			        )
			    )
			VAR MaxUsers = MAXX(AgentUserCounts, [@UniqueUsers])
			VAR MostVersatile = 
			    FILTER(
			        AgentUserCounts,
			        [@UniqueUsers] = MaxUsers
			    )
			RETURN
			    CONCATENATEX(MostVersatile, 'Chat + Agent Interactions (Audit Logs)'[AgentName], ", ")
			```
		lineageTag: 3673341d-b0ab-42fe-9efa-06440654aa0a

	/// Most used agent by sessions
	/// 🏆 Your champion agent
	/// 💡 Study for success patterns
	measure 'Most Popular Agent' =
			
			-- Lists the agent(s) behind the activity in the current cell.
			-- Identity per row: AgentName when present, else AppHost
			-- (e.g. "Logic App", "Autonomous", "Excel") so Workflow Automation
			-- rows that have no AgentName still surface a meaningful identifier.
			-- Top 3 by row count, comma-joined; suffix " +N more" if there's a tail.
			VAR Tagged =
			    SELECTCOLUMNS(
			        FILTER(
			            'Chat + Agent Interactions (Audit Logs)',
			            'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE"
			            && (
			                ('Chat + Agent Interactions (Audit Logs)'[Environment] IN {"Agents", "Autonomous Agent"})
			                || (
			                    NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentName]))
			                        && 'Chat + Agent Interactions (Audit Logs)'[AgentName] <> ""
			                )
			            )
			        ),
			        "@Identity",
			            IF(
			                NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentName]))
			                    && 'Chat + Agent Interactions (Audit Logs)'[AgentName] <> "",
			                'Chat + Agent Interactions (Audit Logs)'[AgentName],
			                COALESCE('Chat + Agent Interactions (Audit Logs)'[AppHost], "Unknown")
			            )
			    )
			VAR IdentityCounts =
			    GROUPBY(
			        Tagged,
			        [@Identity],
			        "@Rows", COUNTX(CURRENTGROUP(), 1)
			    )
			VAR TotalIdentities = COUNTROWS(IdentityCounts)
			VAR Top3 = TOPN(3, IdentityCounts, [@Rows], DESC)
			VAR Names = CONCATENATEX(Top3, [@Identity], ", ", [@Rows], DESC)
			VAR Remainder = TotalIdentities - 3
			RETURN
			    IF(ISBLANK(TotalIdentities) || TotalIdentities = 0,
			        BLANK(),
			        Names & IF(Remainder > 0, " +" & FORMAT(Remainder, "0") & " more", "")
			    )
		lineageTag: 2fcb35a1-90b3-47bf-bc41-4103a2ab5069

