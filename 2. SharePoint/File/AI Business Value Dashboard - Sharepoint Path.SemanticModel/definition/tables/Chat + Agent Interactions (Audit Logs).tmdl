	/// Date-only copy of InteractionDate used for the Calendar relationship (lower cardinality than raw datetime)
	column ActivityDate = 'Chat + Agent Interactions (Audit Logs)'[InteractionDate]
		dataType: dateTime
		formatString: General Date
		lineageTag: 23423086-31bb-4769-bba6-455d200862c5
