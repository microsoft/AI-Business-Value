	/// AI Usage Mode (4-stage Bloom's-aligned maturity model)
	/// 1-Asking (Remember) → 2-Consuming (Understand) → 3-Finding (Apply) → 4-Producing (Create + Expert)
	column Usage_Mode =
			VAR behavior = 'Chat + Agent Interactions (Audit Logs)'[Behavior_Enriched_Full]
			VAR env = 'Chat + Agent Interactions (Audit Logs)'[Environment]
			VAR appHost = LOWER('Chat + Agent Interactions (Audit Logs)'[AppHost])
			VAR appIdentity = LOWER(COALESCE('Chat + Agent Interactions (Audit Logs)'[AppIdentity_AppId], ""))
			VAR isAutomating =
			    env = "Autonomous Agent"
			    || appHost = "copilot studio"
			    || CONTAINSSTRING(appIdentity, "copilot.studio")
			    || behavior IN {"Workflow Execution","Task Management","Meeting Scheduling"}
			RETURN
			    IF(isAutomating, "5 - Automating",
			    IF(behavior IN {"Email Drafting","Document Drafting","Presentation Creation","Image Generation","Code Writing","Code Analysis","Code Analysis (URL)","Data Querying","Spreadsheet Analysis","Excel Assistance","Agent: Content Generation","Agent: Ideation & Creative","Agent: Research & Analysis","Agent: Data & Reporting","Agent: Sales & Customer","Agent: HR & People","Agent: IT & Service Desk","Agent: Compliance & Policy","Agent: Coaching","Agent: Coaching (URL)","Domain-Specific Agent","Cross-Org Agent","Form / Survey Work","Real-time Collaboration"}, "4 - Producing",
			    IF(behavior IN {"Document Summarising","Email Summarising","Email Thread Summary","Email Triage","Presentation Summarising","Video Summarising","Meeting Prep","Note Taking","Teams Messaging","Image / Media Analysis","Image/Media Analysis"}, "3 - Consuming",
			    IF(behavior IN {"Web Searching","Enterprise Searching","PDF Analysis","SharePoint Access","File Retrieval","People Lookup","Agent: Knowledge Base","Spreadsheet Review"}, "2 - Finding",
			    "1 - Asking"))))
		dataType: string
		lineageTag: ff030001-0001-0001-0001-000000000020
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Skill role AI is augmenting — broader than the original specialist-only definition.
	/// Covers comms, content, presentations, design, meetings, research, data, collaboration
	/// in addition to the strict specialist roles. 18 distinct roles total.
	/// Generic Q&A / chat catch-alls remain BLANK by design (no clear skill being augmented).
	column Expertise_Role =
			VAR behavior = 'Chat + Agent Interactions (Audit Logs)'[Behavior_Enriched_Full]
			RETURN
			    -- Specialist roles (strict — kept from original definition)
			    IF(behavior IN {"Data Querying","Agent: Data & Reporting","Spreadsheet Analysis"}, "Data Analyst",
			    IF(behavior IN {"Code Writing","Code Analysis","Code Analysis (URL)"}, "Software Engineer",
			    IF(behavior IN {"Agent: Research & Analysis"}, "Business Analyst",
			    IF(behavior IN {"Agent: Compliance & Policy","Sensitive Content Interaction"}, "Compliance Specialist",
			    IF(behavior IN {"Agent: Sales & Customer"}, "Sales Consultant",
			    IF(behavior IN {"Agent: IT & Service Desk"}, "IT Specialist",
			    IF(behavior IN {"Agent: HR & People"}, "HR Specialist",
			    IF(behavior IN {"Agent: Coaching","Agent: Coaching (URL)"}, "Coach",
			    IF(behavior IN {"Workflow Execution","Task Management"}, "Automation Engineer",
			    IF(behavior IN {"Domain-Specific Agent","Cross-Org Agent"}, "Domain Expert",
			    -- Broader skill roles (NEW — knowledge-worker fundamentals AI is augmenting)
			    IF(behavior IN {"Email Drafting","Email Triage","Email Summarising","Email Thread Summary","Teams Messaging"}, "Communications Specialist",
			    IF(behavior IN {"Document Drafting","Agent: Content Generation","Note Taking","Document Summarising"}, "Content Writer",
			    IF(behavior IN {"Presentation Creation","Presentation Summarising"}, "Presentation Designer",
			    IF(behavior IN {"Image Generation","Image/Media Analysis","Image / Media Analysis","Agent: Ideation & Creative"}, "Visual Designer",
			    IF(behavior IN {"Meeting Prep","Meeting Scheduling","Video Summarising"}, "Meeting Coordinator",
			    IF(behavior IN {"Web Searching","Enterprise Searching","PDF Analysis","SharePoint Access","File Retrieval","People Lookup","Agent: Knowledge Base"}, "Researcher",
			    IF(behavior IN {"Spreadsheet Review","Excel Assistance"}, "Spreadsheet Specialist",
			    IF(behavior IN {"Real-time Collaboration","Form / Survey Work","Form/Survey Work"}, "Collaboration Lead",
			    BLANK()))))))))))))))))))
		dataType: string
		lineageTag: ff030001-0001-0001-0001-000000000095
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Efficiency breakdown: where is time being saved?
	/// Revised Efficiency Breakdown: 12 categories validated across 4 datasets
	column Efficiency_Breakdown =
			VAR behavior = 'Chat + Agent Interactions (Audit Logs)'[Behavior_Enriched_Full]
			VAR cat = 'Chat + Agent Interactions (Audit Logs)'[Behavior_Category]
			RETURN
			    IF(behavior IN {"Email Summarising","Email Triage","Email Thread Summary","Email Drafting"}, "Email",
			    IF(behavior IN {"Document Summarising","Note Taking","Document Drafting","Agent: Content Generation"}, "Document Assistance",
			    IF(behavior IN {"Presentation Summarising","Presentation Creation"}, "Presentations",
			    IF(behavior IN {"Meeting Prep","Video Summarising","Meeting Scheduling"}, "Meetings",
			    IF(behavior IN {"Web Searching","Enterprise Searching","PDF Analysis","SharePoint Access","File Retrieval","People Lookup","Agent: Knowledge Base","Agent: Research & Analysis"}, "Search & Research",
			    IF(behavior IN {"Spreadsheet Review","Excel Assistance","Spreadsheet Analysis","Data Querying","Agent: Data & Reporting"}, "Data & Spreadsheets",
			    IF(behavior IN {"Image Generation","Image / Media Analysis","Image/Media Analysis","Agent: Ideation & Creative","Code Writing","Code Analysis","Code Analysis (URL)"}, "Creative & Technical",
			    IF(behavior IN {"Teams Messaging","Real-time Collaboration","Form / Survey Work","Task Management","Workflow Execution"}, "Collaboration & Workflows",
			    IF(behavior IN {"Agent: Sales & Customer","Agent: IT & Service Desk","Agent: HR & People","Agent: Compliance & Policy","Agent: Coaching","Agent: Coaching (URL)","Domain-Specific Agent","Cross-Org Agent"}, "Specialist Agents",
			    IF(cat = "Teams Q&A", "Teams Chat",
			    IF(cat = "M365 Chat Q&A", "BizChat Q&A",
			    IF(cat = "Browser Q&A", "BizChat Q&A",
			    "General Q&A"))))))))))))
		dataType: string
		lineageTag: ff030001-0001-0001-0001-000000000096
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

