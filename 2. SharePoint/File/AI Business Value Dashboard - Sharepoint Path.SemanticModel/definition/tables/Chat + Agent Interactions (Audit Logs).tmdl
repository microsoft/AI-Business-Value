		lineageTag: f2974e6e-3a26-4c27-a72c-3a8e6129529f

		changedProperty = IsHidden

	/// Average days agents users are active monthly
	/// ✅ >8 days = strong agent adoption
	/// 💡 Compare to chat-only users
	measure 'Average Agent Active Days Per User' =
			
			AVERAGEX(
			    VALUES('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			    CALCULATE(
			        DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[InteractionDate]),
			        'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
			        NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentId]))
			    )
			)
		lineageTag: 1ece3323-cea1-459f-9ca4-9d475ed2e359

