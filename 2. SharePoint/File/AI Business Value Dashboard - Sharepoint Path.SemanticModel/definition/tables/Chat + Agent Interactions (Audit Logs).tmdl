	measure 'Average Chat Sessions Per User Per Week (All Licenses)' = ```
			
			AVERAGEX(
			    VALUES('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			    VAR TotalSessions =
			        CALCULATE(
			            DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[ThreadId]),
			            'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
			            ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentId]),
			            ALL('Chat + Agent Interactions (Audit Logs)'[WeekStart])
			        )
			    VAR TotalWeeks =
			        CALCULATE(
			            DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[WeekStart]),
			            'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
			            ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentId]),
			            ALL('Chat + Agent Interactions (Audit Logs)'[WeekStart])
			        )
			    RETURN
			        DIVIDE(TotalSessions, TotalWeeks, 0)
