	/// Median sessions per week (unlicensed)
	/// 📊 Typical user behavior
	/// 💡 Less skewed than average
	measure 'Median Chat + Agent Sessions Per User Per Week (Unlicensed)' =
			
			MEDIANX(
			    FILTER(
			        VALUES('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			        CALCULATE(
			            DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[ThreadId]),
			            'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
			            'Chat + Agent Interactions (Audit Logs)'[License Status] = "Unlicensed"
			        ) > 0  -- ✓ ADD THIS FILTER
			    ),
			    VAR TotalSessions =
			        CALCULATE(
			            DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[ThreadId]),
			            'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
			            'Chat + Agent Interactions (Audit Logs)'[License Status] = "Unlicensed",
			            REMOVEFILTERS('Chat + Agent Interactions (Audit Logs)'[WeekStart])
			        )
			    VAR TotalWeeks =
			        CALCULATE(
			            DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[WeekStart]),
			            'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
			            'Chat + Agent Interactions (Audit Logs)'[License Status] = "Unlicensed",
			            REMOVEFILTERS('Chat + Agent Interactions (Audit Logs)'[WeekStart])
			        )
			    RETURN
			        DIVIDE(TotalSessions, TotalWeeks, 0)
			)
