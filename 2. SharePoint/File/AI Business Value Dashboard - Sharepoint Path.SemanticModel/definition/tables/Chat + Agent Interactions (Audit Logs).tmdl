	/// License recommendation score
	/// 🎯 Higher = stronger license candidate
	/// 💡 Based on: usage + engagement + consistency
	measure 'License Priority Score (User)' =
			
			VAR SessionsPW =
			    [Median Chat + Agent Sessions Per User Per Week (Unlicensed)]
			VAR DaysPW =
			    [Median Chat + Agent Active Days Per User Per Week (Unlicensed)]
			VAR Intensity =
			    DIVIDE(SessionsPW, DaysPW, 0)
			RETURN
			IF(
			    SessionsPW <= 0 || DaysPW <= 0,
			    BLANK(),
			    -- Option 1: Simple additive (if you have benchmark values)
			    (0.60 * DIVIDE(SessionsPW, 10, 0)) +     -- normalized to 10 sessions/week
			    (0.30 * DIVIDE(DaysPW, 5, 0)) +          -- normalized to 5 days/week
			    (0.10 * DIVIDE(Intensity, 5, 0))         -- normalized to 5 sessions/day
			)
		lineageTag: ce411199-5b7e-4555-bdaf-dd5d6c00aa3e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// % of licensed Copilot users also using agents
