	column 'Agent Last Used Date' =
			LOOKUPVALUE(
			    AgentMetrics[AgentLastUsedDate],
			    AgentMetrics[AgentName],
			    'Chat + Agent Interactions (Audit Logs)'[AgentName]
			)
		formatString: General Date
		lineageTag: 8704c57b-fb9f-453b-b02d-cd18226f282b
