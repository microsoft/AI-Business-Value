			```
		lineageTag: 8c9066bf-26b1-4451-a735-860c5e86d0a3

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Average Active Days (Unlicensed) - Constant Line' = ```
			
			VAR LastMonthStart = CALCULATE([_LastMonthStart], ALL('Chat + Agent Interactions (Audit Logs)'))
			VAR LastMonthEnd = CALCULATE(EOMONTH([_MaxDate], -1), ALL('Chat + Agent Interactions (Audit Logs)'))
			VAR TotalActiveDays = 
			    CALCULATE(
			        SUMX(
			            VALUES('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			            CALCULATE(
			                DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[InteractionDate]),
			                'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE"
			            )
			        ),
			        ALL('Chat + Agent Interactions (Audit Logs)'),
			        'Chat + Agent Interactions (Audit Logs)'[Has license] = "FALSE",
			        'Chat + Agent Interactions (Audit Logs)'[InteractionDate] >= LastMonthStart,
			        'Chat + Agent Interactions (Audit Logs)'[InteractionDate] <= LastMonthEnd
			    )
			VAR TotalUsers = 
			    CALCULATE(
			        DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			        ALL('Chat + Agent Interactions (Audit Logs)'),
			        'Chat + Agent Interactions (Audit Logs)'[Has license] = "FALSE",
			        'Chat + Agent Interactions (Audit Logs)'[InteractionDate] >= LastMonthStart,
			        'Chat + Agent Interactions (Audit Logs)'[InteractionDate] <= LastMonthEnd
			    )
			RETURN
			    DIVIDE(TotalActiveDays, TotalUsers, 0)
			```
		lineageTag: 35e66580-b553-47f3-99a2-a1cbf204077a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

