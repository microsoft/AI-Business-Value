		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	column 'License Status' =
			VAR LicenseVal = UPPER(TRIM('Chat + Agent Interactions (Audit Logs)'[Has license]))
			RETURN
			IF(
			    LicenseVal = "YES" || LicenseVal = "TRUE" || LicenseVal = "Y" || LicenseVal = "1",
			    "M365 Copilot Licensed",
			    "Unlicensed"
			)
		dataType: string
		lineageTag: a6863ae7-217a-49f5-805c-62ef4677c5d0
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	column Environment =
			VAR hasAgent = NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentName])) && 'Chat + Agent Interactions (Audit Logs)'[AgentName] <> ""
			VAR hasAgentId = NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AgentId])) && 'Chat + Agent Interactions (Audit Logs)'[AgentId] <> ""
			VAR appHost = LOWER('Chat + Agent Interactions (Audit Logs)'[AppHost])
			VAR license = UPPER(TRIM('Chat + Agent Interactions (Audit Logs)'[Has license]))
			RETURN
			    IF(appHost IN {"autonomous","logic app"}, "Autonomous Agent",
			    IF(CONTAINSSTRING(appHost, "cowork"), "Cowork",
			    IF(hasAgent || hasAgentId, "Agents",
			    IF(license IN {"YES","TRUE","Y","1"}, "Licensed M365 Copilot",
			    "Unlicensed Chat"))))
		dataType: string
		lineageTag: ff030001-0001-0001-0001-000000000004
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Is_Sensitive =
			(NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[SensitivityLabelId])) && 'Chat + Agent Interactions (Audit Logs)'[SensitivityLabelId] <> "")
			|| (NOT(ISBLANK('Chat + Agent Interactions (Audit Logs)'[AccessedResource_SensitivityLabelId])) && 'Chat + Agent Interactions (Audit Logs)'[AccessedResource_SensitivityLabelId] <> "")
		dataType: boolean
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: ff030001-0001-0001-0001-000000000006
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Human-readable AI model label based on ModelTransparencyDetails
	column AI_Model =
			VAR modelName = UPPER('Chat + Agent Interactions (Audit Logs)'[ModelTransparencyDetails_ModelName])
			RETURN
			    IF(ISBLANK(modelName) || modelName = "NULL" || modelName = "", "Embedded App (no model logged)",
			    IF(CONTAINSSTRING(modelName, "DEEP_LEO"), "GPT-4 (Standard)",
			    IF(CONTAINSSTRING(modelName, "REASONING"), "Reasoning Model (o1/o3)",
			    IF(CONTAINSSTRING(modelName, "OFFENSIVE"), "Safety Filter (blocked)",
			    IF(CONTAINSSTRING(modelName, "GPT-41") || CONTAINSSTRING(modelName, "GPT-4.1"), "GPT-4.1 (Next Gen)",
			    IF(CONTAINSSTRING(modelName, "O3-MINI") || CONTAINSSTRING(modelName, "O3MINI"), "o3-mini (Reasoning)",
			    IF(CONTAINSSTRING(modelName, "O3") || CONTAINSSTRING(modelName, "O1"), "Reasoning Model (o-series)",
			    IF(CONTAINSSTRING(modelName, "GPT-5") || CONTAINSSTRING(modelName, "GPT5"), "GPT-5 (Next Gen)",
			    IF(CONTAINSSTRING(modelName, "CLAUDE"), "Claude (Anthropic)",
			    IF(CONTAINSSTRING(modelName, "GEMINI"), "Gemini (Google)",
			    IF(CONTAINSSTRING(modelName, "LLAMA") || CONTAINSSTRING(modelName, "META"), "LLaMA (Meta)",
			    IF(CONTAINSSTRING(modelName, "PHI"), "Phi (Microsoft Small Model)",
			    modelName))))))))))))
		dataType: string
		lineageTag: ff030001-0001-0001-0001-000000000178
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Frontier Firm Autonomy Pattern. Single categorical column pairing with user % / hours measures. Derived from Environment.
	column Autonomy_Pattern =
			VAR env = 'Chat + Agent Interactions (Audit Logs)'[Environment]
			RETURN
			    IF(env = "Licensed M365 Copilot", "1 - Copilot",
			    IF(env = "Agents", "2 - Agent-Assisted",
			    IF(env = "Autonomous Agent", "3 - Autonomous",
			    BLANK())))
		dataType: string
		lineageTag: ff0d0001-0001-0001-0001-000000000010
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Composite key (UserId|YYYY-MM) for joining to UserMonthMetrics — computed in DAX, not M
	column UserMonthKey =
			'Chat + Agent Interactions (Audit Logs)'[Audit_UserId] & "|" &
			FORMAT('Chat + Agent Interactions (Audit Logs)'[MonthStart], "yyyy-MM")
		dataType: string
		isHidden
		lineageTag: ff030001-0001-0001-0001-000000000200
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

