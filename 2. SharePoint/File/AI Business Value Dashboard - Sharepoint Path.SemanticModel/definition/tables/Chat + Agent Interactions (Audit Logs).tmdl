	/// % of users in current stage leveraging this Usage Mode, Behavior, or Breakdown (works at all drill levels)
	measure '% of Users in Stage' = ```
			
			    VAR UsersInContext =
			        CALCULATE(
			            DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			            'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE"
			        )
			    VAR TotalUsersInStage =
			        CALCULATE(
			            DISTINCTCOUNT('Chat + Agent Interactions (Audit Logs)'[Audit_UserId]),
			            'Chat + Agent Interactions (Audit Logs)'[Message_isPrompt] = "TRUE",
			            REMOVEFILTERS('Chat + Agent Interactions (Audit Logs)'[Usage_Mode]),
			            REMOVEFILTERS('Chat + Agent Interactions (Audit Logs)'[Behavior_Enriched_Full]),
			            REMOVEFILTERS('Chat + Agent Interactions (Audit Logs)'[Behavior_Category]),
			            REMOVEFILTERS('Chat + Agent Interactions (Audit Logs)'[Value_Outcome]),
			            REMOVEFILTERS('Chat + Agent Interactions (Audit Logs)'[Efficiency_Breakdown]),
			            REMOVEFILTERS('Chat + Agent Interactions (Audit Logs)'[Expertise_Role])
			        )
			    RETURN DIVIDE(UsersInContext, TotalUsersInStage, 0)
			```
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: AI Fluency\Usage Modes
		lineageTag: ff030001-0001-0001-0001-000000000029

	/// Specialist jobs performed
	measure 'New Expertise - Jobs' =
			CALCULATE(
			    COUNTROWS('Chat + Agent Interactions (Audit Logs)'),
