    "objects": {
      "general": [
        {
          "properties": {
            "paragraphs": [
              {
                "textRuns": [
                  {
                    "value": "HOW VALUE IS CALCULATED",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontFamily": "Segoe UI",
                      "fontSize": "10pt",
                      "color": "#666666"
                    }
                  }
                ],
                "horizontalTextAlignment": "center"
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Every Copilot interaction generates an audit signal — what app was used, what resources were accessed, what actions were taken. Each signal is classified into an ",
                    "textStyle": {
                      "fontFamily": "Segoe UI",
                      "fontSize": "10pt",
                      "color": "#666666"
                    }
                  },
                  {
                    "value": "AI Task",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontFamily": "Segoe UI",
                      "fontSize": "10pt",
                      "color": "#666666"
                    }
                  },
                  {
                    "value": " (e.g., Email Drafting, Data Querying, Meeting Prep). Each task maps to a ",
                    "textStyle": {
                      "fontFamily": "Segoe UI",
                      "fontSize": "10pt",
                      "color": "#666666"
                    }
                  },
                  {
                    "value": "Value Category",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontFamily": "Segoe UI",
                      "fontSize": "10pt",
                      "color": "#666666"
                    }
                  },
                  {
                    "value": ": either ",
                    "textStyle": {
                      "fontFamily": "Segoe UI",
                      "fontSize": "10pt",
                      "color": "#666666"
                    }
                  },
                  {
                    "value": "Time Saved",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontFamily": "Segoe UI",
                      "fontSize": "10pt",
                      "color": "#666666"
                    }
                  },
                  {
                    "value": " (how much faster the work gets done) or ",
                    "textStyle": {
                      "fontFamily": "Segoe UI",
                      "fontSize": "10pt",
                      "color": "#666666"
                    }
                  },
                  {
                    "value": "Augmented Skill",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontFamily": "Segoe UI",
                      "fontSize": "10pt",
                      "color": "#666666"
                    }
                  },
                  {
                    "value": " (specialist expertise AI provides that the user doesn't have). Each task carries a research-sourced human time baseline — the hours a person would spend doing that work manually. The sum of these baselines is the ",
                    "textStyle": {
                      "fontFamily": "Segoe UI",
                      "fontSize": "10pt",
                      "color": "#666666"
                    }
                  },
                  {
                    "value": "Hours Saved",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontFamily": "Segoe UI",
                      "fontSize": "10pt",
                      "color": "#666666"
                    }
                  },
                  {
                    "value": ". Multiply by an average hourly rate to get the ",
                    "textStyle": {
                      "fontFamily": "Segoe UI",
                      "fontSize": "10pt",
                      "color": "#666666"
                    }
                  },
                  {
                    "value": "Assisted Value",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontFamily": "Segoe UI",
                      "fontSize": "10pt",
                      "color": "#666666"
                    }
                  },
                  {
                    "value": " — the dollar return on your AI investment.",
                    "textStyle": {
                      "fontFamily": "Segoe UI",
                      "fontSize": "10pt",
                      "color": "#666666"
                    }
                  }
                ],
                "horizontalTextAlignment": "center"
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Signal → AI Task → Hours Saved / Augmented Skill → ",
                    "textStyle": {
                      "fontFamily": "Segoe UI",
                      "fontSize": "12pt",
